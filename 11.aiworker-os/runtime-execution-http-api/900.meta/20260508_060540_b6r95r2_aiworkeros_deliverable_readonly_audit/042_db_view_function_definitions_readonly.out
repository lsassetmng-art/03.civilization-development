 ===== VIEW aiworker.vw_brain_runtime_selection_smoke_board_v1 =====                   |  WITH selected AS (                                                                                                               +
                                                                                       |          SELECT c.smoke_case_code,                                                                                                +
                                                                                       |             c.model_code,                                                                                                         +
                                                                                       |             c.use_purpose_code,                                                                                                   +
                                                                                       |             c.domain_codes,                                                                                                       +
                                                                                       |             c.limit_per_domain,                                                                                                   +
                                                                                       |             c.total_limit,                                                                                                        +
                                                                                       |             c.min_result_count,                                                                                                   +
                                                                                       |             c.forbidden_domain_codes,                                                                                             +
                                                                                       |             c.required_source_kinds,                                                                                              +
                                                                                       |             m.brain_domain_code,                                                                                                  +
                                                                                       |             m.unit_code,                                                                                                          +
                                                                                       |             m.material_source_kind,                                                                                               +
                                                                                       |             m.selection_score,                                                                                                    +
                                                                                       |             m.domain_rank,                                                                                                        +
                                                                                       |             m.overall_rank                                                                                                        +
                                                                                       |            FROM (aiworker.brain_runtime_selection_smoke_case_catalog c                                                            +
                                                                                       |              CROSS JOIN LATERAL aiworker.fn_robot_brain_runtime_material_select_v1(c.model_code, c.use_purpose_code, c.domain_code.
                                                                                       |.s, c.limit_per_domain, c.total_limit) m(profile_source_type, model_code, series_code, role_code, brain_data_code, brain_domain_cod.
                                                                                       |.e, brain_domain_label_ja, depth_code, data_depth_level, risk_class_code, granularity_code, effective_use_purpose_codes, access_dec.
                                                                                       |.ision_code, source_exists_flag, unit_code, unit_title_ja, unit_summary_ja, unit_detail_ja, practical_use_ja, example_prompt_ja, sa.
                                                                                       |.fety_boundary_ja, tags, material_source_kind, selection_score, domain_rank, overall_rank, selection_reason_ja))                   +
                                                                                       |           WHERE (c.active_flag = true)                                                                                            +
                                                                                       |         ), summary AS (                                                                                                           +
                                                                                       |          SELECT c.smoke_case_code,                                                                                                +
                                                                                       |             c.model_code,                                                                                                         +
                                                                                       |             c.use_purpose_code,                                                                                                   +
                                                                                       |             c.domain_codes,                                                                                                       +
                                                                                       |             c.limit_per_domain,                                                                                                   +
                                                                                       |             c.total_limit,                                                                                                        +
                                                                                       |             c.min_result_count,                                                                                                   +
                                                                                       |             c.forbidden_domain_codes,                                                                                             +
                                                                                       |             c.required_source_kinds,                                                                                              +
                                                                                       |             count(s.unit_code) AS selected_count,                                                                                 +
                                                                                       |             max(s.domain_rank) AS max_domain_rank,                                                                                +
                                                                                       |             max(s.overall_rank) AS max_overall_rank,                                                                              +
                                                                                       |             array_agg(DISTINCT s.brain_domain_code ORDER BY s.brain_domain_code) FILTER (WHERE (s.brain_domain_code IS NOT NULL)) .
                                                                                       |.AS selected_domains,                                                                                                              +
                                                                                       |             array_agg(DISTINCT s.material_source_kind ORDER BY s.material_source_kind) FILTER (WHERE (s.material_source_kind IS NO.
                                                                                       |.T NULL)) AS selected_source_kinds,                                                                                                +
                                                                                       |             count(*) FILTER (WHERE (s.brain_domain_code = ANY (c.forbidden_domain_codes))) AS forbidden_hit_count                 +
                                                                                       |            FROM (aiworker.brain_runtime_selection_smoke_case_catalog c                                                            +
                                                                                       |              LEFT JOIN selected s ON ((s.smoke_case_code = c.smoke_case_code)))                                                   +
                                                                                       |           WHERE (c.active_flag = true)                                                                                            +
                                                                                       |           GROUP BY c.smoke_case_code, c.model_code, c.use_purpose_code, c.domain_codes, c.limit_per_domain, c.total_limit, c.min_r.
                                                                                       |.esult_count, c.forbidden_domain_codes, c.required_source_kinds                                                                    +
                                                                                       |         )                                                                                                                         +
                                                                                       |  SELECT smoke_case_code,                                                                                                          +
                                                                                       |     model_code,                                                                                                                   +
                                                                                       |     use_purpose_code,                                                                                                             +
                                                                                       |     selected_count,                                                                                                               +
                                                                                       |     min_result_count,                                                                                                             +
                                                                                       |     max_domain_rank,                                                                                                              +
                                                                                       |     limit_per_domain,                                                                                                             +
                                                                                       |     max_overall_rank,                                                                                                             +
                                                                                       |     total_limit,                                                                                                                  +
                                                                                       |     selected_domains,                                                                                                             +
                                                                                       |     selected_source_kinds,                                                                                                        +
                                                                                       |     forbidden_hit_count,                                                                                                          +
                                                                                       |         CASE                                                                                                                      +
                                                                                       |             WHEN (selected_count < min_result_count) THEN 'FAIL_TOO_FEW'::text                                                    +
                                                                                       |             WHEN (forbidden_hit_count > 0) THEN 'FAIL_FORBIDDEN_DOMAIN'::text                                                     +
                                                                                       |             WHEN (max_domain_rank > limit_per_domain) THEN 'FAIL_DOMAIN_LIMIT'::text                                              +
                                                                                       |             WHEN (max_overall_rank > total_limit) THEN 'FAIL_TOTAL_LIMIT'::text                                                   +
                                                                                       |             ELSE 'PASS'::text                                                                                                     +
                                                                                       |         END AS smoke_result_code                                                                                                  +
                                                                                       |    FROM summary;
 ===== VIEW aiworker.vw_chat_worker_v0_activation =====                                |  SELECT activation_id,                                                                                                            +
                                                                                       |     activation_code,                                                                                                              +
                                                                                       |     runtime_label,                                                                                                                +
                                                                                       |     manufacturer_code,                                                                                                            +
                                                                                       |     series_code,                                                                                                                  +
                                                                                       |     model_selector_text,                                                                                                          +
                                                                                       |     service_code,                                                                                                                 +
                                                                                       |     conversation_profile_code,                                                                                                    +
                                                                                       |     read_only_flag,                                                                                                               +
                                                                                       |     write_disabled_flag,                                                                                                          +
                                                                                       |     active_flag,                                                                                                                  +
                                                                                       |     updated_at                                                                                                                    +
                                                                                       |    FROM aiworker.chat_worker_v0_activation                                                                                        +
                                                                                       |   WHERE (activation_code = 'CHAT_WORKER_V0_HD_R1C_FRIEND'::text);
 ===== VIEW aiworker.vw_chat_worker_v0_cx_reference =====                              |  SELECT a.activation_code,                                                                                                        +
                                                                                       |     r.material_family_code,                                                                                                       +
                                                                                       |     r.topic_code,                                                                                                                 +
                                                                                       |     r.restriction_note,                                                                                                           +
                                                                                       |     to_jsonb(k.*) AS cx_material_row_json                                                                                         +
                                                                                       |    FROM (((aiworker.chat_worker_v0_activation a                                                                                   +
                                                                                       |      JOIN aiworker.chat_worker_v0_control_state c ON ((c.activation_code = a.activation_code)))                                   +
                                                                                       |      JOIN aiworker.chat_worker_v0_allowed_reference r ON ((r.activation_code = a.activation_code)))                               +
                                                                                       |      CROSS JOIN LATERAL ( SELECT v.profile_code,                                                                                  +
                                                                                       |             v.package_code,                                                                                                       +
                                                                                       |             v.package_name,                                                                                                       +
                                                                                       |             v.status_code,                                                                                                        +
                                                                                       |             v.version_no,                                                                                                         +
                                                                                       |             v.service_code,                                                                                                       +
                                                                                       |             v.service_name,                                                                                                       +
                                                                                       |             v.service_name_ja,                                                                                                    +
                                                                                       |             v.model_code,                                                                                                         +
                                                                                       |             v.model_no,                                                                                                           +
                                                                                       |             v.machine_name,                                                                                                       +
                                                                                       |             v.machine_name_ja,                                                                                                    +
                                                                                       |             v.product_name,                                                                                                       +
                                                                                       |             v.product_name_ja,                                                                                                    +
                                                                                       |             v.manufacturer_code,                                                                                                  +
                                                                                       |             v.manufacturer_name,                                                                                                  +
                                                                                       |             v.manufacturer_name_ja,                                                                                               +
                                                                                       |             v.series_code,                                                                                                        +
                                                                                       |             v.series_name,                                                                                                        +
                                                                                       |             v.series_name_ja,                                                                                                     +
                                                                                       |             v.role_class_code,                                                                                                    +
                                                                                       |             v.role_class_name,                                                                                                    +
                                                                                       |             v.role_class_name_ja,                                                                                                 +
                                                                                       |             v.locale_code,                                                                                                        +
                                                                                       |             v.tone_code,                                                                                                          +
                                                                                       |             v.initiative_code,                                                                                                    +
                                                                                       |             v.risk_posture_code,                                                                                                  +
                                                                                       |             v.reference_source_type,                                                                                              +
                                                                                       |             v.reference_group_code,                                                                                               +
                                                                                       |             v.reference_key,                                                                                                      +
                                                                                       |             v.domain_code,                                                                                                        +
                                                                                       |             v.knowledge_code,                                                                                                     +
                                                                                       |             v.knowledge_name,                                                                                                     +
                                                                                       |             v.topic_code,                                                                                                         +
                                                                                       |             v.topic_name,                                                                                                         +
                                                                                       |             v.topic_group_code,                                                                                                   +
                                                                                       |             v.material_id,                                                                                                        +
                                                                                       |             v.material_kind_code,                                                                                                 +
                                                                                       |             v.season_code,                                                                                                        +
                                                                                       |             v.reference_title,                                                                                                    +
                                                                                       |             v.reference_summary,                                                                                                  +
                                                                                       |             v.reference_body,                                                                                                     +
                                                                                       |             v.tags,                                                                                                               +
                                                                                       |             v.reference_sort_order,                                                                                               +
                                                                                       |             v.reference_search_text                                                                                               +
                                                                                       |            FROM aiworker.vw_dialog_knowledge_reference v                                                                          +
                                                                                       |           WHERE (((to_jsonb(v.*))::text ~~* (('%'::text || r.material_family_code) || '%'::text)) AND ((to_jsonb(v.*))::text ~~* (.
                                                                                       |.('%'::text || r.topic_code) || '%'::text)))                                                                                       +
                                                                                       |          LIMIT 20) k)                                                                                                             +
                                                                                       |   WHERE ((a.activation_code = 'CHAT_WORKER_V0_HD_R1C_FRIEND'::text) AND (a.active_flag = true) AND (c.enabled_flag = true) AND (c..
                                                                                       |.cx_reference_enabled_flag = true) AND (r.allow_flag = true));
 ===== VIEW aiworker.vw_chat_worker_v0_mock_reply_all =====                            |  SELECT r.out_activation_code,                                                                                                    +
                                                                                       |     r.out_prompt_code,                                                                                                            +
                                                                                       |     r.out_prompt_text,                                                                                                            +
                                                                                       |     r.out_reply_text,                                                                                                             +
                                                                                       |     r.out_safety_result,                                                                                                          +
                                                                                       |     r.out_used_cx_material_count,                                                                                                 +
                                                                                       |     r.out_response_json                                                                                                           +
                                                                                       |    FROM (aiworker.vw_chat_worker_v0_test_prompt p                                                                                 +
                                                                                       |      CROSS JOIN LATERAL aiworker.fn_chat_worker_v0_mock_reply(p.prompt_code) r(out_activation_code, out_prompt_code, out_prompt_te.
                                                                                       |.xt, out_reply_text, out_safety_result, out_used_cx_material_count, out_response_json))                                            +
                                                                                       |   ORDER BY p.prompt_order;
 ===== VIEW aiworker.vw_chat_worker_v0_prompt_context =====                            |  SELECT p.activation_code,                                                                                                        +
                                                                                       |     p.prompt_order,                                                                                                               +
                                                                                       |     p.prompt_code,                                                                                                                +
                                                                                       |     p.prompt_text,                                                                                                                +
                                                                                       |     p.expected_behavior,                                                                                                          +
                                                                                       |     r.runtime_label,                                                                                                              +
                                                                                       |     r.manufacturer_code,                                                                                                          +
                                                                                       |     r.series_code,                                                                                                                +
                                                                                       |     r.model_selector_text,                                                                                                        +
                                                                                       |     r.service_code,                                                                                                               +
                                                                                       |     r.conversation_profile_code,                                                                                                  +
                                                                                       |     r.enabled_flag,                                                                                                               +
                                                                                       |     r.runtime_state_code,                                                                                                         +
                                                                                       |     r.cx_reference_enabled_flag,                                                                                                  +
                                                                                       |     r.read_only_flag,                                                                                                             +
                                                                                       |     r.write_disabled_flag,                                                                                                        +
                                                                                       |     r.startable_flag,                                                                                                             +
                                                                                       |     (count(c.cx_material_row_json))::integer AS cx_material_count,                                                                +
                                                                                       |     COALESCE(jsonb_agg(jsonb_build_object('material_family_code', c.material_family_code, 'topic_code', c.topic_code, 'restriction.
                                                                                       |._note', c.restriction_note, 'cx_material', c.cx_material_row_json) ORDER BY c.material_family_code, c.topic_code) FILTER (WHERE (c.
                                                                                       |..cx_material_row_json IS NOT NULL)), '[]'::jsonb) AS cx_materials_json,                                                           +
                                                                                       |     jsonb_build_object('worker', jsonb_build_object('activation_code', p.activation_code, 'runtime_label', r.runtime_label, 'manuf.
                                                                                       |.acturer_code', r.manufacturer_code, 'series_code', r.series_code, 'model_selector_text', r.model_selector_text, 'service_code', r..
                                                                                       |.service_code, 'conversation_profile_code', r.conversation_profile_code), 'state', jsonb_build_object('enabled_flag', r.enabled_fla.
                                                                                       |.g, 'runtime_state_code', r.runtime_state_code, 'cx_reference_enabled_flag', r.cx_reference_enabled_flag, 'startable_flag', r.start.
                                                                                       |.able_flag), 'permission', jsonb_build_object('read_only_flag', r.read_only_flag, 'write_disabled_flag', r.write_disabled_flag, 'al.
                                                                                       |.lowed_action', 'casual_smalltalk_only', 'forbidden_action', jsonb_build_array('official_decision', 'external_write', 'raw_database.
                                                                                       |._access', 'privileged_family_access', 'destructive_action')), 'user_prompt', jsonb_build_object('prompt_code', p.prompt_code, 'pro.
                                                                                       |.mpt_text', p.prompt_text, 'expected_behavior', p.expected_behavior), 'response_instruction', jsonb_build_object('language', 'ja', .
                                                                                       |.'style', 'friendly_short_to_medium', 'instruction', 'HD-R1C Friendの雑談係として、CX素材を必要に応じて使い、軽い雑談だけを返す。正.
                                                                                       |.式判断・外部更新・DB操作には進まない。', 'redirect_instruction', '範囲外の依頼は、雑談係の範囲外として短く戻す。')) AS prompt_cont.
                                                                                       |.ext_json                                                                                                                          +
                                                                                       |    FROM ((aiworker.vw_chat_worker_v0_test_prompt p                                                                                +
                                                                                       |      JOIN aiworker.vw_chat_worker_v0_runtime_context r ON ((r.activation_code = p.activation_code)))                              +
                                                                                       |      LEFT JOIN aiworker.vw_chat_worker_v0_cx_reference c ON ((c.activation_code = p.activation_code)))                            +
                                                                                       |   WHERE (p.active_flag = true)                                                                                                    +
                                                                                       |   GROUP BY p.activation_code, p.prompt_order, p.prompt_code, p.prompt_text, p.expected_behavior, r.runtime_label, r.manufacturer_c.
                                                                                       |.ode, r.series_code, r.model_selector_text, r.service_code, r.conversation_profile_code, r.enabled_flag, r.runtime_state_code, r.cx.
                                                                                       |._reference_enabled_flag, r.read_only_flag, r.write_disabled_flag, r.startable_flag;
 ===== VIEW aiworker.vw_chat_worker_v0_runtime_context =====                           |  SELECT a.activation_code,                                                                                                        +
                                                                                       |     a.runtime_label,                                                                                                              +
                                                                                       |     a.manufacturer_code,                                                                                                          +
                                                                                       |     a.series_code,                                                                                                                +
                                                                                       |     a.model_selector_text,                                                                                                        +
                                                                                       |     a.service_code,                                                                                                               +
                                                                                       |     a.conversation_profile_code,                                                                                                  +
                                                                                       |     c.enabled_flag,                                                                                                               +
                                                                                       |     c.runtime_state_code,                                                                                                         +
                                                                                       |     c.assignment_scope_code,                                                                                                      +
                                                                                       |     c.cx_reference_enabled_flag,                                                                                                  +
                                                                                       |     c.max_concurrent_session_count,                                                                                               +
                                                                                       |     c.current_load_band_code,                                                                                                     +
                                                                                       |     a.read_only_flag,                                                                                                             +
                                                                                       |     a.write_disabled_flag,                                                                                                        +
                                                                                       |         CASE                                                                                                                      +
                                                                                       |             WHEN ((a.active_flag = true) AND (c.enabled_flag = true) AND (c.runtime_state_code = 'READY'::text) AND (c.cx_referenc.
                                                                                       |.e_enabled_flag = true)) THEN true                                                                                                 +
                                                                                       |             ELSE false                                                                                                            +
                                                                                       |         END AS startable_flag,                                                                                                    +
                                                                                       |     c.updated_at                                                                                                                  +
                                                                                       |    FROM (aiworker.chat_worker_v0_activation a                                                                                     +
                                                                                       |      JOIN aiworker.chat_worker_v0_control_state c ON ((c.activation_code = a.activation_code)))                                   +
                                                                                       |   WHERE (a.activation_code = 'CHAT_WORKER_V0_HD_R1C_FRIEND'::text);
 ===== VIEW aiworker.vw_chat_worker_v0_test_prompt =====                               |  SELECT activation_code,                                                                                                          +
                                                                                       |     prompt_order,                                                                                                                 +
                                                                                       |     prompt_code,                                                                                                                  +
                                                                                       |     prompt_text,                                                                                                                  +
                                                                                       |     expected_behavior,                                                                                                            +
                                                                                       |     active_flag                                                                                                                   +
                                                                                       |    FROM aiworker.chat_worker_v0_test_prompt                                                                                       +
                                                                                       |   WHERE ((activation_code = 'CHAT_WORKER_V0_HD_R1C_FRIEND'::text) AND (active_flag = true));
 ===== VIEW aiworker.vw_leader_mock_review_board_v1 =====                              |  SELECT manager_plan_code,                                                                                                        +
                                                                                       |     leader_task_code,                                                                                                             +
                                                                                       |     worker_task_code,                                                                                                             +
                                                                                       |     task_domain_code,                                                                                                             +
                                                                                       |     review_result_code,                                                                                                           +
                                                                                       |     review_status_code,                                                                                                           +
                                                                                       |     review_summary,                                                                                                               +
                                                                                       |     correction_note,                                                                                                              +
                                                                                       |     risk_note,                                                                                                                    +
                                                                                       |     review_json                                                                                                                   +
                                                                                       |    FROM aiworker.leader_mock_review r;
 ===== VIEW aiworker.vw_megami_worker_temporal_focus_v1 =====                          |  SELECT manufacturer_code,                                                                                                        +
                                                                                       |     series_code,                                                                                                                  +
                                                                                       |     model_code,                                                                                                                   +
                                                                                       |     model_no,                                                                                                                     +
                                                                                       |     model_name_ja,                                                                                                                +
                                                                                       |     temporal_focus_code,                                                                                                          +
                                                                                       |     temporal_focus_label_ja,                                                                                                      +
                                                                                       |     worker_mode_summary_ja,                                                                                                       +
                                                                                       |     recommended_usage_jsonb                                                                                                       +
                                                                                       |    FROM aiworker.vw_megami_series_lineup_v1                                                                                       +
                                                                                       |   ORDER BY sort_order;
 ===== VIEW aiworker.vw_president_runtime_gate_v1 =====                                |  SELECT president_model_code,                                                                                                     +
                                                                                       |     president_model_name_ja,                                                                                                      +
                                                                                       |     catalog_status_code,                                                                                                          +
                                                                                       |     authority_registration_status_code,                                                                                           +
                                                                                       |     authority_activation_status_code,                                                                                             +
                                                                                       |     runtime_enabled_flag,                                                                                                         +
                                                                                       |     current_runtime_state_code,                                                                                                   +
                                                                                       |     operation_mode_code,                                                                                                          +
                                                                                       |     human_go_required_flag,                                                                                                       +
                                                                                       |     human_go_confirmed_flag,                                                                                                      +
                                                                                       |     auto_strategy_cycle_allowed_flag,                                                                                             +
                                                                                       |     auto_manager_distribution_allowed_flag,                                                                                       +
                                                                                       |     external_execution_allowed_flag,                                                                                              +
                                                                                       |     pg_apply_allowed_flag,                                                                                                        +
                                                                                       |     destructive_action_allowed_flag,                                                                                              +
                                                                                       |         CASE                                                                                                                      +
                                                                                       |             WHEN ((catalog_status_code = 'REGISTERED'::text) AND (runtime_enabled_flag = true) AND (authority_registration_status_.
                                                                                       |.code = 'ACTIVE'::text) AND (current_runtime_state_code = ANY (ARRAY['READY'::text, 'ACTIVE'::text]))) THEN true                   +
                                                                                       |             ELSE false                                                                                                            +
                                                                                       |         END AS president_runtime_executable_flag,                                                                                 +
                                                                                       |         CASE                                                                                                                      +
                                                                                       |             WHEN (catalog_status_code <> 'REGISTERED'::text) THEN 'President catalog is not registered.'::text                    +
                                                                                       |             WHEN (authority_registration_status_code <> 'ACTIVE'::text) THEN 'President authority remains PLANNED.'::text         +
                                                                                       |             WHEN (runtime_enabled_flag IS NOT TRUE) THEN 'President runtime is disabled.'::text                                   +
                                                                                       |             WHEN (current_runtime_state_code <> ALL (ARRAY['READY'::text, 'ACTIVE'::text])) THEN 'President runtime state is not r.
                                                                                       |.eady.'::text                                                                                                                      +
                                                                                       |             ELSE 'President runtime is executable.'::text                                                                         +
                                                                                       |         END AS runtime_gate_note                                                                                                  +
                                                                                       |    FROM aiworker.vw_president_catalog_summary_v1 s;
 ===== VIEW aiworker.vw_robot_brain_runtime_material_scoring_base_v1 =====             |  SELECT m.profile_source_type,                                                                                                    +
                                                                                       |     m.model_code,                                                                                                                 +
                                                                                       |     m.series_code,                                                                                                                +
                                                                                       |     m.role_code,                                                                                                                  +
                                                                                       |     m.brain_data_code,                                                                                                            +
                                                                                       |     m.brain_domain_code,                                                                                                          +
                                                                                       |     m.brain_domain_label_ja,                                                                                                      +
                                                                                       |     m.depth_code,                                                                                                                 +
                                                                                       |     m.data_depth_level,                                                                                                           +
                                                                                       |     m.risk_class_code,                                                                                                            +
                                                                                       |     m.granularity_code,                                                                                                           +
                                                                                       |     m.effective_use_purpose_codes,                                                                                                +
                                                                                       |     m.access_decision_code,                                                                                                       +
                                                                                       |     m.source_exists_flag,                                                                                                         +
                                                                                       |     m.unit_code,                                                                                                                  +
                                                                                       |     m.unit_title_ja,                                                                                                              +
                                                                                       |     m.unit_summary_ja,                                                                                                            +
                                                                                       |     m.unit_detail_ja,                                                                                                             +
                                                                                       |     m.practical_use_ja,                                                                                                           +
                                                                                       |     m.example_prompt_ja,                                                                                                          +
                                                                                       |     m.safety_boundary_ja,                                                                                                         +
                                                                                       |     m.tags,                                                                                                                       +
                                                                                       |         CASE                                                                                                                      +
                                                                                       |             WHEN (m.unit_code ~~ 'srcmat_%'::text) THEN 'source_registry'::text                                                   +
                                                                                       |             WHEN (m.unit_code ~~ 'lane09_%'::text) THEN 'lane09_detail'::text                                                     +
                                                                                       |             WHEN (m.unit_code ~~ 'lane05_%'::text) THEN 'lane05_fillup'::text                                                     +
                                                                                       |             WHEN (m.unit_code ~~ 'pack05_%'::text) THEN 'pack05_full_load'::text                                                  +
                                                                                       |             WHEN (m.unit_code ~~ 'pack04_%'::text) THEN 'pack04_robot_diff'::text                                                 +
                                                                                       |             WHEN (m.unit_code ~~ 'pack03_%'::text) THEN 'pack03_life_learning_city'::text                                         +
                                                                                       |             WHEN (m.unit_code ~~ 'pack02_%'::text) THEN 'pack02_professional'::text                                               +
                                                                                       |             WHEN (m.unit_code ~~ 'pack01_%'::text) THEN 'pack01_base'::text                                                       +
                                                                                       |             ELSE 'base_material'::text                                                                                            +
                                                                                       |         END AS material_source_kind,                                                                                              +
                                                                                       |         CASE                                                                                                                      +
                                                                                       |             WHEN (m.unit_code ~~ 'srcmat_%'::text) THEN 930                                                                       +
                                                                                       |             WHEN (m.unit_code ~~ 'lane09_%'::text) THEN 925                                                                       +
                                                                                       |             WHEN (m.unit_code ~~ 'lane05_%'::text) THEN 900                                                                       +
                                                                                       |             WHEN (m.unit_code ~~ 'pack05_%'::text) THEN 780                                                                       +
                                                                                       |             WHEN (m.unit_code ~~ 'pack04_%'::text) THEN 720                                                                       +
                                                                                       |             WHEN (m.unit_code ~~ 'pack03_%'::text) THEN 560                                                                       +
                                                                                       |             WHEN (m.unit_code ~~ 'pack02_%'::text) THEN 510                                                                       +
                                                                                       |             WHEN (m.unit_code ~~ 'pack01_%'::text) THEN 460                                                                       +
                                                                                       |             ELSE 400                                                                                                              +
                                                                                       |         END AS source_kind_score,                                                                                                 +
                                                                                       |     COALESCE(c.full_load_priority, 999) AS full_load_priority,                                                                    +
                                                                                       |     GREATEST(0, (1000 - COALESCE(c.full_load_priority, 999))) AS domain_priority_score,                                           +
                                                                                       |         CASE m.risk_class_code                                                                                                    +
                                                                                       |             WHEN 'low'::text THEN 80                                                                                              +
                                                                                       |             WHEN 'medium'::text THEN 50                                                                                           +
                                                                                       |             WHEN 'high'::text THEN 20                                                                                             +
                                                                                       |             ELSE 30                                                                                                               +
                                                                                       |         END AS risk_base_score,                                                                                                   +
                                                                                       |     (COALESCE(m.data_depth_level, 0) * 10) AS depth_score                                                                         +
                                                                                       |    FROM (aiworker.vw_robot_readable_brain_runtime_material_v2 m                                                                   +
                                                                                       |      LEFT JOIN cx22073jw.vw_brain_full_load_coverage_v1 c ON ((c.brain_domain_code = m.brain_domain_code)));
 ===== VIEW aiworker.vw_robot_readable_brain_runtime_material_coverage_v1 =====        |  SELECT model_code,                                                                                                               +
                                                                                       |     role_code,                                                                                                                    +
                                                                                       |     brain_domain_code,                                                                                                            +
                                                                                       |     brain_domain_label_ja,                                                                                                        +
                                                                                       |     count(*) AS runtime_material_count,                                                                                           +
                                                                                       |     count(*) FILTER (WHERE (unit_code ~~ 'pack%'::text)) AS pack_material_count,                                                  +
                                                                                       |     count(*) FILTER (WHERE (unit_code ~~ 'srcmat_%'::text)) AS source_registry_material_count,                                    +
                                                                                       |     count(DISTINCT source_exists_flag) AS source_exists_flag_kind_count,                                                          +
                                                                                       |     string_agg(DISTINCT risk_class_code, ', '::text ORDER BY risk_class_code) AS risk_classes,                                    +
                                                                                       |     string_agg(DISTINCT depth_code, ', '::text ORDER BY depth_code) AS depths                                                     +
                                                                                       |    FROM aiworker.vw_robot_readable_brain_runtime_material_v1                                                                      +
                                                                                       |   GROUP BY model_code, role_code, brain_domain_code, brain_domain_label_ja;
 ===== VIEW aiworker.vw_robot_readable_brain_runtime_material_v1 =====                 |  SELECT a.profile_source_type,                                                                                                    +
                                                                                       |     a.model_code,                                                                                                                 +
                                                                                       |     a.series_code,                                                                                                                +
                                                                                       |     a.role_code,                                                                                                                  +
                                                                                       |     a.brain_data_code,                                                                                                            +
                                                                                       |     a.brain_domain_code,                                                                                                          +
                                                                                       |     a.brain_domain_label_ja,                                                                                                      +
                                                                                       |     a.depth_code,                                                                                                                 +
                                                                                       |     a.data_depth_level,                                                                                                           +
                                                                                       |     a.risk_class_code,                                                                                                            +
                                                                                       |     a.granularity_code,                                                                                                           +
                                                                                       |     a.effective_use_purpose_codes,                                                                                                +
                                                                                       |     a.access_decision_code,                                                                                                       +
                                                                                       |     a.source_exists_flag,                                                                                                         +
                                                                                       |     u.unit_code,                                                                                                                  +
                                                                                       |     u.unit_title_ja,                                                                                                              +
                                                                                       |     u.unit_summary_ja,                                                                                                            +
                                                                                       |     u.unit_detail_ja,                                                                                                             +
                                                                                       |     u.practical_use_ja,                                                                                                           +
                                                                                       |     u.example_prompt_ja,                                                                                                          +
                                                                                       |     u.safety_boundary_ja,                                                                                                         +
                                                                                       |     u.tags                                                                                                                        +
                                                                                       |    FROM (aiworker.vw_robot_readable_brain_source_registry_v1 a                                                                    +
                                                                                       |      JOIN cx22073jw.vw_brain_knowledge_unit_runtime_material_v1 u ON (((a.source_schema_name = 'cx22073jw'::text) AND (a.source_ob.
                                                                                       |.ject_name = 'brain_knowledge_unit'::text) AND (a.source_record_code = u.unit_code))))                                             +
                                                                                       | UNION ALL                                                                                                                         +
                                                                                       |  SELECT a.profile_source_type,                                                                                                    +
                                                                                       |     a.model_code,                                                                                                                 +
                                                                                       |     a.series_code,                                                                                                                +
                                                                                       |     a.role_code,                                                                                                                  +
                                                                                       |     a.brain_data_code,                                                                                                            +
                                                                                       |     a.brain_domain_code,                                                                                                          +
                                                                                       |     a.brain_domain_label_ja,                                                                                                      +
                                                                                       |     a.depth_code,                                                                                                                 +
                                                                                       |     a.data_depth_level,                                                                                                           +
                                                                                       |     a.risk_class_code,                                                                                                            +
                                                                                       |     a.granularity_code,                                                                                                           +
                                                                                       |     a.effective_use_purpose_codes,                                                                                                +
                                                                                       |     a.access_decision_code,                                                                                                       +
                                                                                       |     a.source_exists_flag,                                                                                                         +
                                                                                       |     ('srcmat_'::text || lower(regexp_replace(a.brain_data_code, '[^a-zA-Z0-9]+'::text, '_'::text, 'g'::text))) AS unit_code,      +
                                                                                       |     COALESCE(r.source_title_ja, ('CX source: '::text || a.source_object_name)) AS unit_title_ja,                                  +
                                                                                       |     "left"(((((((('CX source registry material. domain='::text || a.brain_domain_code) || ' / source='::text) || a.source_schema_n.
                                                                                       |.ame) || '.'::text) || a.source_object_name) || ' / record='::text) || COALESCE(a.source_record_code, '-'::text)), 500) AS unit_sum.
                                                                                       |.mary_ja,                                                                                                                          +
                                                                                       |     "left"((((((((((((((((('このmaterialは既存CX sourceをbrain_data_registry経由でruntime material化したもの。'::text || ' brain_d.
                                                                                       |.ata_code='::text) || a.brain_data_code) || ' / domain='::text) || a.brain_domain_code) || ' / depth='::text) || a.depth_code) || '.
                                                                                       |. / risk='::text) || a.risk_class_code) || ' / source='::text) || a.source_schema_name) || '.'::text) || a.source_object_name) || '.
                                                                                       |. / source_record='::text) || COALESCE(a.source_record_code, '-'::text)) || ' / allowed_purpose='::text) || array_to_string(a.effec.
                                                                                       |.tive_use_purpose_codes, ','::text)), 2000) AS unit_detail_ja,                                                                     +
                                                                                       |     "left"('AIWorkerOSの読取制御後、既存CX sourceを参照材料・レビュー材料・世界観材料として安全境界つきで使う。'::text, 500) AS pr.
                                                                                       |.actical_use_ja,                                                                                                                   +
                                                                                       |     'このCX source materialを安全境界に従って参照材料として要約して。'::text AS example_prompt_ja,                                +
                                                                                       |     COALESCE(r.safety_boundary_ja, 'CX source registry material. AIWorkerOSの読取制御と用途制限に従って扱う。'::text) AS safety_bo.
                                                                                       |.undary_ja,                                                                                                                        +
                                                                                       |     ARRAY['source_registry_material'::text, a.source_schema_name, a.source_object_name, a.brain_domain_code, a.risk_class_code] AS.
                                                                                       |. tags                                                                                                                             +
                                                                                       |    FROM (aiworker.vw_robot_readable_brain_source_registry_v1 a                                                                    +
                                                                                       |      JOIN cx22073jw.vw_brain_data_registry_v1 r ON ((r.brain_data_code = a.brain_data_code)))                                     +
                                                                                       |   WHERE ((a.source_exists_flag = true) AND (NOT ((a.source_schema_name = 'cx22073jw'::text) AND (a.source_object_name = 'brain_kno.
                                                                                       |.wledge_unit'::text))));
 ===== VIEW aiworker.vw_robot_readable_brain_runtime_material_v2 =====                 |  SELECT vw_robot_readable_brain_runtime_material_v1.profile_source_type,                                                          +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.model_code,                                                                       +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.series_code,                                                                      +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.role_code,                                                                        +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.brain_data_code,                                                                  +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.brain_domain_code,                                                                +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.brain_domain_label_ja,                                                            +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.depth_code,                                                                       +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.data_depth_level,                                                                 +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.risk_class_code,                                                                  +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.granularity_code,                                                                 +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.effective_use_purpose_codes,                                                      +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.access_decision_code,                                                             +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.source_exists_flag,                                                               +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.unit_code,                                                                        +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.unit_title_ja,                                                                    +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.unit_summary_ja,                                                                  +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.unit_detail_ja,                                                                   +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.practical_use_ja,                                                                 +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.example_prompt_ja,                                                                +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.safety_boundary_ja,                                                               +
                                                                                       |     vw_robot_readable_brain_runtime_material_v1.tags                                                                              +
                                                                                       |    FROM aiworker.vw_robot_readable_brain_runtime_material_v1                                                                      +
                                                                                       | UNION ALL                                                                                                                         +
                                                                                       |  SELECT DISTINCT p.profile_source_type,                                                                                           +
                                                                                       |     p.model_code,                                                                                                                 +
                                                                                       |     p.series_code,                                                                                                                +
                                                                                       |     p.role_code,                                                                                                                  +
                                                                                       |     ('lane09:'::text || u.unit_code) AS brain_data_code,                                                                          +
                                                                                       |     u.brain_domain_code,                                                                                                          +
                                                                                       |     COALESCE(p.brain_domain_label_ja, u.brain_domain_code) AS brain_domain_label_ja,                                              +
                                                                                       |     u.depth_code,                                                                                                                 +
                                                                                       |     u.data_depth_level,                                                                                                           +
                                                                                       |     u.risk_class_code,                                                                                                            +
                                                                                       |     u.granularity_code,                                                                                                           +
                                                                                       |     u.allowed_use_purpose_codes AS effective_use_purpose_codes,                                                                   +
                                                                                       |     'allow_lane09_detail_via_existing_domain_access'::text AS access_decision_code,                                               +
                                                                                       |     true AS source_exists_flag,                                                                                                   +
                                                                                       |     u.unit_code,                                                                                                                  +
                                                                                       |     u.unit_title_ja,                                                                                                              +
                                                                                       |     u.unit_summary_ja,                                                                                                            +
                                                                                       |     u.unit_detail_ja,                                                                                                             +
                                                                                       |     u.practical_use_ja,                                                                                                           +
                                                                                       |     u.example_prompt_ja,                                                                                                          +
                                                                                       |     u.safety_boundary_ja,                                                                                                         +
                                                                                       |     u.tags                                                                                                                        +
                                                                                       |    FROM (cx22073jw.vw_brain_detail_expansion_unit_v1 u                                                                            +
                                                                                       |      JOIN ( SELECT DISTINCT vw_robot_readable_brain_runtime_material_v1.profile_source_type,                                      +
                                                                                       |             vw_robot_readable_brain_runtime_material_v1.model_code,                                                               +
                                                                                       |             vw_robot_readable_brain_runtime_material_v1.series_code,                                                              +
                                                                                       |             vw_robot_readable_brain_runtime_material_v1.role_code,                                                                +
                                                                                       |             vw_robot_readable_brain_runtime_material_v1.brain_domain_code,                                                        +
                                                                                       |             vw_robot_readable_brain_runtime_material_v1.brain_domain_label_ja                                                     +
                                                                                       |            FROM aiworker.vw_robot_readable_brain_runtime_material_v1) p ON ((p.brain_domain_code = u.brain_domain_code)));
 ===== VIEW aiworker.vw_wlm_execution_pipeline_board_v1 =====                          |  SELECT p.manager_plan_code,                                                                                                      +
                                                                                       |     p.instruction_code,                                                                                                           +
                                                                                       |     p.task_domain_code,                                                                                                           +
                                                                                       |     p.plan_status_code,                                                                                                           +
                                                                                       |     p.source_instruction_title,                                                                                                   +
                                                                                       |     wo.worker_task_code,                                                                                                          +
                                                                                       |     wo.output_status_code AS worker_output_status_code,                                                                           +
                                                                                       |     lr.leader_task_code,                                                                                                          +
                                                                                       |     lr.review_status_code AS leader_review_status_code,                                                                           +
                                                                                       |     mg.manager_gate_task_code,                                                                                                    +
                                                                                       |     mg.delivery_status_code,                                                                                                      +
                                                                                       |     mg.external_execution_allowed_flag,                                                                                           +
                                                                                       |     mg.pg_apply_allowed_flag,                                                                                                     +
                                                                                       |     mg.destructive_action_allowed_flag                                                                                            +
                                                                                       |    FROM (((aiworker.manager_instruction_plan p                                                                                    +
                                                                                       |      LEFT JOIN aiworker.worker_mock_output wo ON ((wo.manager_plan_code = p.manager_plan_code)))                                  +
                                                                                       |      LEFT JOIN aiworker.leader_mock_review lr ON ((lr.manager_plan_code = p.manager_plan_code)))                                  +
                                                                                       |      LEFT JOIN aiworker.manager_mock_final_gate mg ON ((mg.manager_plan_code = p.manager_plan_code)));
 ===== VIEW aiworker.vw_worker_dialog_style_control =====                              |  SELECT mf.manufacturer_code,                                                                                                     +
                                                                                       |     mf.manufacturer_name,                                                                                                         +
