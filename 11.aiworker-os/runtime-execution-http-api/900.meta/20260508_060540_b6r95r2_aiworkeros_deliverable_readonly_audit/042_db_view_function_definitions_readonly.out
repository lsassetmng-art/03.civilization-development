                                                                                       |     series_code,                                                                                                                  +
                                                                                       |     series_name,                                                                                                                  +
                                                                                       |     series_name_ja,                                                                                                               +
                                                                                       |     model_code,                                                                                                                   +
                                                                                       |     model_no,                                                                                                                     +
                                                                                       |     model_name,                                                                                                                   +
                                                                                       |     model_name_ja,                                                                                                                +
                                                                                       |     role_layer_code,                                                                                                              +
                                                                                       |     role_layer_name_ja,                                                                                                           +
                                                                                       |     model_category_code,                                                                                                          +
                                                                                       |     public_summary_ja,                                                                                                            +
                                                                                       |     capability_summary_ja,                                                                                                        +
                                                                                       |     personality_summary_ja,                                                                                                       +
                                                                                       |     safety_note_ja,                                                                                                               +
                                                                                       |     public_traits_jsonb,                                                                                                          +
                                                                                       |     recommended_usage_jsonb,                                                                                                      +
                                                                                       |     source_layer_code,                                                                                                            +
                                                                                       |     sort_order                                                                                                                    +
                                                                                       |    FROM aiworker.model_public_registry                                                                                            +
                                                                                       |   WHERE ((status_code = 'active'::text) AND (public_display_allowed_flag = true) AND (app_reference_allowed_flag = true));
 ===== VIEW aiworker.vw_app_aiworker_model_selection_source_for_capability_v1 =====    |  SELECT registry_code,                                                                                                            +
                                                                                       |     manufacturer_code,                                                                                                            +
                                                                                       |     manufacturer_name,                                                                                                            +
                                                                                       |     manufacturer_name_ja,                                                                                                         +
                                                                                       |     series_code,                                                                                                                  +
                                                                                       |     series_name,                                                                                                                  +
                                                                                       |     series_name_ja,                                                                                                               +
                                                                                       |     model_code,                                                                                                                   +
                                                                                       |     model_no,                                                                                                                     +
                                                                                       |     model_name,                                                                                                                   +
                                                                                       |     model_name_ja,                                                                                                                +
                                                                                       |     role_layer_code,                                                                                                              +
                                                                                       |     role_layer_name_ja,                                                                                                           +
                                                                                       |     model_category_code,                                                                                                          +
                                                                                       |     public_summary_ja,                                                                                                            +
                                                                                       |     capability_summary_ja,                                                                                                        +
                                                                                       |     personality_summary_ja,                                                                                                       +
                                                                                       |     safety_note_ja,                                                                                                               +
                                                                                       |     public_traits_jsonb,                                                                                                          +
                                                                                       |     recommended_usage_jsonb,                                                                                                      +
                                                                                       |     source_layer_code,                                                                                                            +
