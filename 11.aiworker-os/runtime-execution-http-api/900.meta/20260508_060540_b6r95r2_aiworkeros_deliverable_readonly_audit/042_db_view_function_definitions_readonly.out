                                                                                       |     sr.series_code,                                                                                                               +
                                                                                       |     sr.series_name,                                                                                                               +
                                                                                       |     sr.series_name_ja,                                                                                                            +
                                                                                       |     m.model_code,                                                                                                                 +
                                                                                       |     m.model_no,                                                                                                                   +
                                                                                       |     m.machine_name,                                                                                                               +
                                                                                       |     m.machine_name_ja,                                                                                                            +
                                                                                       |     m.product_name,                                                                                                               +
                                                                                       |     m.product_name_ja,                                                                                                            +
                                                                                       |     m.role_class_code,                                                                                                            +
                                                                                       |     rc.role_class_name,                                                                                                           +
                                                                                       |     rc.role_class_name_ja,                                                                                                        +
                                                                                       |     svc.service_code,                                                                                                             +
                                                                                       |     svc.service_name,                                                                                                             +
                                                                                       |     svc.service_name_ja,                                                                                                          +
                                                                                       |     st.style_code,                                                                                                                +
                                                                                       |     st.style_no,                                                                                                                  +
                                                                                       |     st.style_name,                                                                                                                +
                                                                                       |     st.style_name_ja,                                                                                                             +
                                                                                       |     st.style_summary,                                                                                                             +
                                                                                       |     st.initiative_code,                                                                                                           +
                                                                                       |     st.warmth_code,                                                                                                               +
                                                                                       |     st.tempo_code,                                                                                                                +
                                                                                       |     st.closeness_code,                                                                                                            +
                                                                                       |     "overlay".opener_overlay,                                                                                                     +
                                                                                       |     "overlay".followup_overlay,                                                                                                   +
                                                                                       |     "overlay".closing_overlay,                                                                                                    +
                                                                                       |     "overlay".redirect_overlay,                                                                                                   +
                                                                                       |     lower(concat_ws(' '::text, mf.manufacturer_code, mf.manufacturer_name, mf.manufacturer_name_ja, sr.series_code, sr.series_name.
                                                                                       |., sr.series_name_ja, m.model_code, m.model_no, m.machine_name, m.machine_name_ja, m.product_name, m.product_name_ja, COALESCE(rc.r.
                                                                                       |.ole_class_name_ja, ''::text), svc.service_code, svc.service_name, svc.service_name_ja, COALESCE(st.style_name, ''::text), COALESCE.
                                                                                       |.(st.style_name_ja, ''::text))) AS dialog_control_search_text,                                                                     +
                                                                                       |     m.sort_order                                                                                                                  +
                                                                                       |    FROM ((((((((aiworker.worker_model_catalog m                                                                                   +
                                                                                       |      JOIN aiworker.manufacturer_catalog mf ON ((mf.manufacturer_code = m.manufacturer_code)))                                     +
                                                                                       |      JOIN aiworker.worker_series_catalog sr ON ((sr.series_code = m.series_code)))                                                +
                                                                                       |      LEFT JOIN aiworker.worker_role_class_catalog rc ON ((rc.role_class_code = m.role_class_code)))                               +
                                                                                       |      JOIN aiworker.model_service_assignment msa ON (((msa.model_code = m.model_code) AND (msa.enabled = true))))                  +
                                                                                       |      JOIN aiworker.service_catalog svc ON (((svc.service_code = msa.service_code) AND (svc.enabled = true))))                     +
                                                                                       |      LEFT JOIN aiworker.model_style_assignment msa_style ON (((msa_style.model_code = m.model_code) AND (msa_style.enabled = true).
                                                                                       |.)))                                                                                                                               +
                                                                                       |      LEFT JOIN aiworker.interaction_style_catalog st ON (((st.style_code = msa_style.style_code) AND (st.enabled = true))))       +
                                                                                       |      LEFT JOIN aiworker.style_expression_overlay "overlay" ON ((("overlay".style_code = st.style_code) AND ("overlay".service_code.
                                                                                       |. = svc.service_code) AND ("overlay".enabled = true))))                                                                            +
                                                                                       |   WHERE ((m.enabled = true) AND (mf.enabled = true) AND (sr.enabled = true));
