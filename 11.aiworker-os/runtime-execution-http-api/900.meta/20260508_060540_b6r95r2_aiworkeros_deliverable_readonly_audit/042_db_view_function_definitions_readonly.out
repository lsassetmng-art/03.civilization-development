 ===== FUNCTION aiworker.fn_default_summary_band_from_result_code(p_result_code text) =====                                                                                                             | CREATE OR REPLACE.
                                                                                                                                                                                                        |. FUNCTION aiworke.
                                                                                                                                                                                                        |.r.fn_default_summ.
                                                                                                                                                                                                        |.ary_band_from_res.
                                                                                                                                                                                                        |.ult_code(p_result.
                                                                                                                                                                                                        |._code text)      +
                                                                                                                                                                                                        |  RETURNS text    +
                                                                                                                                                                                                        |  LANGUAGE sql    +
                                                                                                                                                                                                        |  IMMUTABLE       +
                                                                                                                                                                                                        | AS $function$    +
                                                                                                                                                                                                        |   select case    +
                                                                                                                                                                                                        |     when p_result.
                                                                                                                                                                                                        |._code = 'OK_APPLI.
                                                                                                                                                                                                        |.ED' then 'STANDAR.
                                                                                                                                                                                                        |.D'               +
                                                                                                                                                                                                        |     when p_result.
                                                                                                                                                                                                        |._code = 'OK_NOOP_.
                                                                                                                                                                                                        |.REPLAY' then 'MIN.
                                                                                                                                                                                                        |.IMAL'            +
                                                                                                                                                                                                        |     when p_result.
                                                                                                                                                                                                        |._code = 'OK_REVIE.
                                                                                                                                                                                                        |.W_REQUIRED' then .
                                                                                                                                                                                                        |.'REVIEW'         +
                                                                                                                                                                                                        |     when p_result.
                                                                                                                                                                                                        |._code = 'NG_GATE_.
                                                                                                                                                                                                        |.DENIED' then 'MIN.
                                                                                                                                                                                                        |.IMAL'            +
                                                                                                                                                                                                        |     when p_result.
                                                                                                                                                                                                        |._code = 'NG_APPRO.
                                                                                                                                                                                                        |.VAL_REQUIRED' the.
                                                                                                                                                                                                        |.n 'REVIEW'       +
                                                                                                                                                                                                        |     when p_result.
                                                                                                                                                                                                        |._code = 'NG_AUDIT.
                                                                                                                                                                                                        |._REQUIRED' then '.
                                                                                                                                                                                                        |.REVIEW'          +
                                                                                                                                                                                                        |     when p_result.
                                                                                                                                                                                                        |._code = 'NG_ILLEG.
                                                                                                                                                                                                        |.AL_TRANSITION' th.
                                                                                                                                                                                                        |.en 'STANDARD'    +
                                                                                                                                                                                                        |     when p_result.
                                                                                                                                                                                                        |._code = 'NG_VALID.
                                                                                                                                                                                                        |.ATION_FAILED' the.
                                                                                                                                                                                                        |.n 'STANDARD'     +
                                                                                                                                                                                                        |     when p_result.
                                                                                                                                                                                                        |._code = 'NG_WORKE.
                                                                                                                                                                                                        |.R_NOT_ELIGIBLE' t.
                                                                                                                                                                                                        |.hen 'STANDARD'   +
                                                                                                                                                                                                        |     when p_result.
                                                                                                                                                                                                        |._code = 'NG_INTER.
                                                                                                                                                                                                        |.NAL_ERROR' then '.
                                                                                                                                                                                                        |.MINIMAL'         +
                                                                                                                                                                                                        |     else 'MINIMAL.
                                                                                                                                                                                                        |.'                +
                                                                                                                                                                                                        |   end            +
                                                                                                                                                                                                        | $function$       +
