                                                                                       |     r.model_code,                                                                                                                 +
                                                                                       |     r.model_no,                                                                                                                   +
                                                                                       |     r.model_name_ja,                                                                                                              +
                                                                                       |     r.task_domain_code,                                                                                                           +
                                                                                       |     r.task_title,                                                                                                                 +
                                                                                       |     lr.review_code,                                                                                                               +
                                                                                       |     lr.review_result_code,                                                                                                        +
                                                                                       |     lr.review_status_code,                                                                                                        +
                                                                                       |     lr.reviewer_role_layer_code,                                                                                                  +
                                                                                       |     lr.review_summary_ja,                                                                                                         +
                                                                                       |     lr.return_for_fix_flag,                                                                                                       +
