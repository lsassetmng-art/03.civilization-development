 ===== VIEW aiworker.vw_app_megami_norn_three_sisters_lineup_with_body_v1 =====        |  SELECT m.manufacturer_code,                                                                                                      +
                                                                                       |     m.series_code,                                                                                                                +
                                                                                       |     m.model_code,                                                                                                                 +
                                                                                       |     m.model_no,                                                                                                                   +
                                                                                       |     m.model_name,                                                                                                                 +
                                                                                       |     m.model_name_ja,                                                                                                              +
                                                                                       |     m.role_layer_code,                                                                                                            +
                                                                                       |     m.role_layer_name_ja,                                                                                                         +
                                                                                       |     COALESCE(mp.norn_code, ''::text) AS norn_code,                                                                                +
                                                                                       |     COALESCE(mp.temporal_focus_code, ''::text) AS temporal_focus_code,                                                            +
                                                                                       |     COALESCE(mp.temporal_focus_label_ja, ''::text) AS temporal_focus_label_ja,                                                    +
                                                                                       |     COALESCE(mp.worker_mode_summary_ja, m.capability_summary) AS worker_mode_summary_ja,                                          +
                                                                                       |     COALESCE(mp.friend_lover_style_family_code, ''::text) AS friend_lover_style_family_code,                                      +
                                                                                       |     COALESCE(mp.friend_lover_style_family_ja, ''::text) AS friend_lover_style_family_ja,                                          +
                                                                                       |     COALESCE(mp.friend_lover_personality_summary_ja, ''::text) AS friend_lover_personality_summary_ja,                            +
                                                                                       |     COALESCE(mp.personality_risk_note_ja, ''::text) AS personality_risk_note_ja,                                                  +
                                                                                       |     COALESCE(mp.safety_overlay_jsonb, '{}'::jsonb) AS safety_overlay_jsonb,                                                       +
                                                                                       |     a.height_cm,                                                                                                                  +
                                                                                       |     a.bust_cm,                                                                                                                    +
                                                                                       |     a.waist_cm,                                                                                                                   +
                                                                                       |     a.hip_cm,                                                                                                                     +
                                                                                       |     a.body_profile_jsonb,                                                                                                         +
                                                                                       |     a.norn_three_sisters_body_condition_pass_flag,                                                                                +
                                                                                       |     a.appearance_profile_note_ja,                                                                                                 +
                                                                                       |     m.sort_order                                                                                                                  +
                                                                                       |    FROM ((aiworker.worker_model_extension_catalog m                                                                               +
                                                                                       |      LEFT JOIN aiworker.megami_model_profile mp ON ((mp.model_code = m.model_code)))                                              +
                                                                                       |      LEFT JOIN aiworker.vw_megami_norn_three_sisters_appearance_profile_v1 a ON ((a.model_code = m.model_code)))                  +
                                                                                       |   WHERE ((m.manufacturer_code = 'mathers_garden'::text) AND (m.series_code = 'megami_series'::text) AND (m.model_code = ANY (ARRAY.
                                                                                       |.['mg_norn_001_urd'::text, 'mg_norn_002_verdandi'::text, 'mg_norn_003_skuld'::text])) AND (m.status_code = 'active'::text))        +
                                                                                       |   ORDER BY m.sort_order;
