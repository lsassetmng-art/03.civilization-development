                                                                                       |     pa.updated_at                                                                                                                 +
                                                                                       |    FROM (aiworker.runtime_president_approval pa                                                                                   +
                                                                                       |      JOIN aiworker.runtime_execution_request r ON ((r.request_id = pa.request_id)))                                               +
                                                                                       |   ORDER BY pa.created_at DESC;
 ===== VIEW aiworker.vw_app_aiworker_runtime_worker_output_board_v1 =====              |  SELECT o.output_id,                                                                                                              +
                                                                                       |     o.request_id,                                                                                                                 +
                                                                                       |     r.request_code,                                                                                                               +
                                                                                       |     r.app_surface_code,                                                                                                           +
                                                                                       |     r.model_code,                                                                                                                 +
                                                                                       |     r.model_no,                                                                                                                   +
                                                                                       |     r.model_name_ja,                                                                                                              +
                                                                                       |     r.series_code,                                                                                                                +
                                                                                       |     r.series_name_ja,                                                                                                             +
                                                                                       |     r.role_layer_code,                                                                                                            +
                                                                                       |     r.role_layer_name_ja,                                                                                                         +
                                                                                       |     r.task_domain_code,                                                                                                           +
                                                                                       |     r.task_title,                                                                                                                 +
                                                                                       |     o.output_code,                                                                                                                +
                                                                                       |     o.output_status_code,                                                                                                         +
                                                                                       |     o.output_result_code,                                                                                                         +
                                                                                       |     o.output_title_ja,                                                                                                            +
                                                                                       |     o.output_summary_ja,                                                                                                          +
                                                                                       |     o.safety_result_code,                                                                                                         +
                                                                                       |     o.external_execution_performed_flag,                                                                                          +
                                                                                       |     o.pg_apply_performed_flag,                                                                                                    +
                                                                                       |     o.destructive_action_performed_flag,                                                                                          +
                                                                                       |     o.created_at,                                                                                                                 +
                                                                                       |     o.updated_at                                                                                                                  +
                                                                                       |    FROM (aiworker.runtime_worker_output o                                                                                         +
                                                                                       |      JOIN aiworker.runtime_execution_request r ON ((r.request_id = o.request_id)))                                                +
                                                                                       |   ORDER BY o.created_at DESC;
