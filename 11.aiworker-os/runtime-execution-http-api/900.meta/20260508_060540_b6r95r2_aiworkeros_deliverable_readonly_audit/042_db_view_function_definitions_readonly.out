                                                                                       |     r.task_title,                                                                                                                 +
                                                                                       |     g.gate_type_code,                                                                                                             +
                                                                                       |     g.gate_status_code,                                                                                                           +
                                                                                       |     g.gate_result_code,                                                                                                           +
                                                                                       |     g.reviewer_role_layer_code,                                                                                                   +
                                                                                       |     g.review_summary_ja,                                                                                                          +
                                                                                       |     g.created_at,                                                                                                                 +
                                                                                       |     g.updated_at                                                                                                                  +
                                                                                       |    FROM (aiworker.runtime_review_gate_log g                                                                                       +
                                                                                       |      JOIN aiworker.runtime_execution_request r ON ((r.request_id = g.request_id)))                                                +
                                                                                       |   ORDER BY g.created_at DESC;
 ===== VIEW aiworker.vw_app_aiworker_runtime_execution_intake_payload_v1 =====         |  SELECT request_id,                                                                                                               +
                                                                                       |     request_code,                                                                                                                 +
                                                                                       |     jsonb_build_object('request_id', request_id, 'request_code', request_code, 'app_surface_code', app_surface_code, 'source_app_r.
                                                                                       |.ef', source_app_ref, 'model_code', model_code, 'model_no', model_no, 'model_name_ja', model_name_ja, 'series_code', series_code, '.
                                                                                       |.role_layer_code', role_layer_code, 'task_domain_code', task_domain_code, 'task_title', task_title, 'task_instruction_ja', task_ins.
                                                                                       |.truction_ja, 'operation_mode_code', operation_mode_code, 'runtime_control', runtime_control_snapshot_jsonb, 'allowed_actions', all.
                                                                                       |.owed_actions_snapshot_jsonb, 'forbidden_actions', forbidden_actions_snapshot_jsonb, 'prompt_fragment_codes', prompt_fragment_codes.
                                                                                       |._snapshot_jsonb, 'safety', jsonb_build_object('external_execution_allowed_flag', external_execution_allowed_flag, 'pg_apply_allowe.
                                                                                       |.d_flag', pg_apply_allowed_flag, 'destructive_action_allowed_flag', destructive_action_allowed_flag, 'human_go_required_flag', huma.
                                                                                       |.n_go_required_flag, 'review_required_flag', review_required_flag)) AS intake_payload_jsonb,                                       +
                                                                                       |     created_at                                                                                                                    +
                                                                                       |    FROM aiworker.runtime_execution_request r                                                                                      +
                                                                                       |   ORDER BY created_at DESC;
