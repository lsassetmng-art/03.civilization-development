                                                                                       |   ORDER BY mg.created_at DESC;
 ===== VIEW aiworker.vw_app_aiworker_runtime_president_approval_board_v1 =====         |  SELECT pa.president_approval_id,                                                                                                 +
                                                                                       |     pa.request_id,                                                                                                                +
                                                                                       |     r.request_code,                                                                                                               +
                                                                                       |     r.app_surface_code,                                                                                                           +
                                                                                       |     r.model_code,                                                                                                                 +
                                                                                       |     r.model_no,                                                                                                                   +
                                                                                       |     r.model_name_ja,                                                                                                              +
                                                                                       |     r.task_domain_code,                                                                                                           +
                                                                                       |     r.task_title,                                                                                                                 +
                                                                                       |     pa.approval_code,                                                                                                             +
                                                                                       |     pa.approval_result_code,                                                                                                      +
                                                                                       |     pa.approval_status_code,                                                                                                      +
                                                                                       |     pa.approval_summary_ja,                                                                                                       +
                                                                                       |     pa.human_go_required_flag,                                                                                                    +
                                                                                       |     pa.external_execution_allowed_flag,                                                                                           +
                                                                                       |     pa.pg_apply_allowed_flag,                                                                                                     +
                                                                                       |     pa.destructive_action_allowed_flag,                                                                                           +
