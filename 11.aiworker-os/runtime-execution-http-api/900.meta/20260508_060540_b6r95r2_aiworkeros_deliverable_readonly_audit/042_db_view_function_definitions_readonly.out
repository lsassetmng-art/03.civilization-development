                                                                                       |   ORDER BY lr.created_at DESC;
 ===== VIEW aiworker.vw_app_aiworker_runtime_manager_gate_board_v1 =====               |  SELECT mg.manager_gate_id,                                                                                                       +
                                                                                       |     mg.request_id,                                                                                                                +
                                                                                       |     r.request_code,                                                                                                               +
                                                                                       |     r.app_surface_code,                                                                                                           +
                                                                                       |     r.model_code,                                                                                                                 +
                                                                                       |     r.model_no,                                                                                                                   +
                                                                                       |     r.model_name_ja,                                                                                                              +
                                                                                       |     r.task_domain_code,                                                                                                           +
                                                                                       |     r.task_title,                                                                                                                 +
                                                                                       |     mg.gate_code,                                                                                                                 +
                                                                                       |     mg.gate_result_code,                                                                                                          +
                                                                                       |     mg.gate_status_code,                                                                                                          +
                                                                                       |     mg.gate_summary_ja,                                                                                                           +
                                                                                       |     mg.return_for_fix_flag,                                                                                                       +
                                                                                       |     mg.external_execution_allowed_flag,                                                                                           +
                                                                                       |     mg.pg_apply_allowed_flag,                                                                                                     +
