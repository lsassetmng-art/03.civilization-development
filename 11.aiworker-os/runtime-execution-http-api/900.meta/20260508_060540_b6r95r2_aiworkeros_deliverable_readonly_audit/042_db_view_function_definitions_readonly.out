                                                                                       |         CASE r.artifact_kind_code                                                                                                 +
                                                                                       |             WHEN 'design_doc'::text THEN '設計書'::text                                                                           +
                                                                                       |             WHEN 'implementation'::text THEN '実装'::text                                                                         +
                                                                                       |             WHEN 'exception'::text THEN '例外'::text                                                                              +
                                                                                       |             WHEN 'delivery_package'::text THEN '納品'::text                                                                       +
                                                                                       |             WHEN 'handoff'::text THEN '引き継ぎ'::text                                                                            +
                                                                                       |             ELSE r.artifact_kind_code                                                                                             +
                                                                                       |         END AS artifact_kind_label,                                                                                               +
                                                                                       |     r.review_title,                                                                                                               +
                                                                                       |     r.delivery_summary_text,                                                                                                      +
                                                                                       |     r.main_changes_text,                                                                                                          +
                                                                                       |     r.ai_review_result_text,                                                                                                      +
                                                                                       |     r.unresolved_issues_text,                                                                                                     +
                                                                                       |     r.artifact_link,                                                                                                              +
                                                                                       |     r.responsible_ai_label,                                                                                                       +
                                                                                       |     r.requested_by_ai_label,                                                                                                      +
                                                                                       |     r.human_review_status_code,                                                                                                   +
                                                                                       |         CASE r.human_review_status_code                                                                                           +
                                                                                       |             WHEN 'pending'::text THEN '承認待ち'::text                                                                            +
                                                                                       |             WHEN 'approved'::text THEN '承認済み'::text                                                                           +
                                                                                       |             WHEN 'returned'::text THEN '差し戻し'::text                                                                           +
                                                                                       |             WHEN 'archived'::text THEN 'アーカイブ'::text                                                                         +
                                                                                       |             ELSE r.human_review_status_code                                                                                       +
                                                                                       |         END AS human_review_status_label,                                                                                         +
                                                                                       |     r.priority_code,                                                                                                              +
