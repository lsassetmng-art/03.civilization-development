                                                                                       |     c.role_class_name_ja,                                                                                                         +
                                                                                       |     c.service_code,                                                                                                               +
                                                                                       |     c.service_name_ja,                                                                                                            +
                                                                                       |     c.style_code,                                                                                                                 +
                                                                                       |     c.style_no,                                                                                                                   +
                                                                                       |     c.style_name_ja,                                                                                                              +
                                                                                       |     b.topic_code,                                                                                                                 +
