 ===== VIEW aiworker.vw_worker_series_directory =====                                  |  SELECT m.manufacturer_code,                                                                                                      +
                                                                                       |     m.manufacturer_name,                                                                                                          +
                                                                                       |     m.manufacturer_name_ja,                                                                                                       +
                                                                                       |     s.series_code,                                                                                                                +
                                                                                       |     s.series_name,                                                                                                                +
                                                                                       |     s.series_name_ja,                                                                                                             +
                                                                                       |     s.series_summary,                                                                                                             +
                                                                                       |     t.initiative_posture_code,                                                                                                    +
                                                                                       |     t.initiative_posture_label,                                                                                                   +
                                                                                       |     t.reasoning_guardrail_code,                                                                                                   +
                                                                                       |     t.reasoning_guardrail_label,                                                                                                  +
                                                                                       |     t.risk_posture_code,                                                                                                          +
                                                                                       |     t.risk_posture_label,                                                                                                         +
                                                                                       |     t.tendency_summary,                                                                                                           +
                                                                                       |     count(mdl.model_code) FILTER (WHERE (mdl.enabled = true)) AS enabled_model_count,                                             +
                                                                                       |     lower(concat_ws(' '::text, m.manufacturer_code, m.manufacturer_name, m.manufacturer_name_ja, s.series_code, s.series_name, s.s.
                                                                                       |.eries_name_ja, COALESCE(s.series_summary, ''::text))) AS series_search_text                                                       +
                                                                                       |    FROM (((aiworker.worker_series_catalog s                                                                                       +
                                                                                       |      JOIN aiworker.manufacturer_catalog m ON ((m.manufacturer_code = s.manufacturer_code)))                                       +
                                                                                       |      LEFT JOIN aiworker.worker_series_tendency t ON (((t.series_code = s.series_code) AND (t.enabled = true))))                   +
                                                                                       |      LEFT JOIN aiworker.worker_model_catalog mdl ON (((mdl.series_code = s.series_code) AND (mdl.enabled = true))))               +
                                                                                       |   WHERE ((m.enabled = true) AND (s.enabled = true))                                                                               +
                                                                                       |   GROUP BY m.manufacturer_code, m.manufacturer_name, m.manufacturer_name_ja, s.series_code, s.series_name, s.series_name_ja, s.ser.
                                                                                       |.ies_summary, t.initiative_posture_code, t.initiative_posture_label, t.reasoning_guardrail_code, t.reasoning_guardrail_label, t.ris.
                                                                                       |.k_posture_code, t.risk_posture_label, t.tendency_summary;
 ===== VIEW aiworker.vw_worker_series_lineup =====                                     |  SELECT m.manufacturer_code,                                                                                                      +
                                                                                       |     m.manufacturer_name,                                                                                                          +
                                                                                       |     m.manufacturer_name_ja,                                                                                                       +
                                                                                       |     s.series_code,                                                                                                                +
                                                                                       |     s.series_name,                                                                                                                +
                                                                                       |     s.series_name_ja,                                                                                                             +
                                                                                       |     rc.role_class_code,                                                                                                           +
                                                                                       |     rc.role_class_name,                                                                                                           +
                                                                                       |     rc.role_class_name_ja,                                                                                                        +
                                                                                       |     rc.governance_rank_no,                                                                                                        +
                                                                                       |     rc.combat_related,                                                                                                            +
                                                                                       |     mdl.model_code,                                                                                                               +
                                                                                       |     mdl.model_no,                                                                                                                 +
                                                                                       |     mdl.machine_name,                                                                                                             +
                                                                                       |     mdl.machine_name_ja,                                                                                                          +
                                                                                       |     mdl.product_name,                                                                                                             +
                                                                                       |     mdl.product_name_ja,                                                                                                          +
                                                                                       |     mdl.model_summary,                                                                                                            +
                                                                                       |     t.initiative_posture_code,                                                                                                    +
                                                                                       |     t.initiative_posture_label,                                                                                                   +
                                                                                       |     t.reasoning_guardrail_code,                                                                                                   +
                                                                                       |     t.reasoning_guardrail_label,                                                                                                  +
                                                                                       |     t.risk_posture_code,                                                                                                          +
                                                                                       |     t.risk_posture_label,                                                                                                         +
                                                                                       |     t.tendency_summary,                                                                                                           +
                                                                                       |         CASE                                                                                                                      +
                                                                                       |             WHEN (rc.governance_rank_no >= 550) THEN 'overall_supreme'::text                                                      +
                                                                                       |             WHEN (rc.governance_rank_no >= 500) THEN 'top_control'::text                                                          +
                                                                                       |             WHEN (rc.governance_rank_no >= 400) THEN 'upper_control'::text                                                        +
                                                                                       |             WHEN (rc.combat_related = true) THEN 'combat'::text                                                                   +
                                                                                       |             WHEN (rc.role_class_code = ANY (ARRAY['friend'::text, 'lover'::text, 'secretary_helper'::text])) THEN 'support_relatio.
                                                                                       |.n'::text                                                                                                                          +
                                                                                       |             ELSE 'general_worker'::text                                                                                           +
                                                                                       |         END AS lineup_group_code,                                                                                                 +
                                                                                       |         CASE                                                                                                                      +
                                                                                       |             WHEN (rc.governance_rank_no >= 550) THEN '全体最高位'::text                                                           +
                                                                                       |             WHEN (rc.governance_rank_no >= 500) THEN '最上位統制'::text                                                           +
                                                                                       |             WHEN (rc.governance_rank_no >= 400) THEN '上位統制'::text                                                             +
                                                                                       |             WHEN (rc.combat_related = true) THEN '戦闘系'::text                                                                   +
                                                                                       |             WHEN (rc.role_class_code = ANY (ARRAY['friend'::text, 'lover'::text, 'secretary_helper'::text])) THEN '関係 / 支援系':.
                                                                                       |.:text                                                                                                                             +
                                                                                       |             ELSE '標準実行系'::text                                                                                               +
                                                                                       |         END AS lineup_group_name_ja,                                                                                              +
                                                                                       |     lower(concat_ws(' '::text, m.manufacturer_code, m.manufacturer_name, m.manufacturer_name_ja, s.series_code, s.series_name, s.s.
                                                                                       |.eries_name_ja, rc.role_class_code, rc.role_class_name, rc.role_class_name_ja, mdl.model_code, mdl.model_no, mdl.machine_name, mdl..
                                                                                       |.machine_name_ja, mdl.product_name, mdl.product_name_ja, COALESCE(mdl.model_summary, ''::text))) AS model_search_text,             +
                                                                                       |     mdl.sort_order                                                                                                                +
                                                                                       |    FROM ((((aiworker.worker_model_catalog mdl                                                                                     +
                                                                                       |      JOIN aiworker.manufacturer_catalog m ON ((m.manufacturer_code = mdl.manufacturer_code)))                                     +
                                                                                       |      JOIN aiworker.worker_series_catalog s ON ((s.series_code = mdl.series_code)))                                                +
                                                                                       |      JOIN aiworker.worker_role_class_catalog rc ON ((rc.role_class_code = mdl.role_class_code)))                                  +
                                                                                       |      LEFT JOIN aiworker.worker_series_tendency t ON (((t.series_code = mdl.series_code) AND (t.enabled = true))))                 +
                                                                                       |   WHERE ((mdl.enabled = true) AND (m.enabled = true) AND (s.enabled = true) AND (rc.enabled = true));
 ===== VIEW aiworker.vw_worker_series_search_directory =====                           |  SELECT mf.manufacturer_code,                                                                                                     +
                                                                                       |     mf.manufacturer_name,                                                                                                         +
                                                                                       |     mf.manufacturer_name_ja,                                                                                                      +
                                                                                       |     sr.series_code,                                                                                                               +
                                                                                       |     sr.series_name,                                                                                                               +
                                                                                       |     sr.series_name_ja,                                                                                                            +
                                                                                       |     sr.series_summary,                                                                                                            +
                                                                                       |     count(m.model_code) FILTER (WHERE (m.enabled = true)) AS enabled_model_count,                                                 +
                                                                                       |     count(DISTINCT id.style_no) FILTER (WHERE (m.enabled = true)) AS style_count,                                                 +
                                                                                       |     count(m.model_code) FILTER (WHERE ((m.enabled = true) AND (id.presentation_gender_code = 'M'::text))) AS male_model_count,    +
                                                                                       |     count(m.model_code) FILTER (WHERE ((m.enabled = true) AND (id.presentation_gender_code = 'F'::text))) AS female_model_count,  +
                                                                                       |     count(p.model_code) FILTER (WHERE ((p.enabled = true) AND (p.live_activity_enabled = true))) AS live_enabled_model_count,     +
                                                                                       |     lower(concat_ws(' '::text, mf.manufacturer_code, mf.manufacturer_name, mf.manufacturer_name_ja, sr.series_code, sr.series_name.
                                                                                       |., sr.series_name_ja, COALESCE(sr.series_summary, ''::text))) AS series_search_text                                                +
                                                                                       |    FROM ((((aiworker.worker_series_catalog sr                                                                                     +
                                                                                       |      JOIN aiworker.manufacturer_catalog mf ON ((mf.manufacturer_code = sr.manufacturer_code)))                                    +
                                                                                       |      LEFT JOIN aiworker.worker_model_catalog m ON (((m.series_code = sr.series_code) AND (m.manufacturer_code = mf.manufacturer_co.
                                                                                       |.de))))                                                                                                                            +
                                                                                       |      LEFT JOIN aiworker.model_identity_spec id ON ((id.model_code = m.model_code)))                                               +
                                                                                       |      LEFT JOIN aiworker.public_activity_profile p ON ((p.model_code = m.model_code)))                                             +
                                                                                       |   WHERE ((mf.enabled = true) AND (sr.enabled = true))                                                                             +
                                                                                       |   GROUP BY mf.manufacturer_code, mf.manufacturer_name, mf.manufacturer_name_ja, sr.series_code, sr.series_name, sr.series_name_ja,.
                                                                                       |. sr.series_summary;
 ===== VIEW aiworker.vw_worker_series_search_lineup =====                              |  SELECT mf.manufacturer_code,                                                                                                     +
                                                                                       |     mf.manufacturer_name,                                                                                                         +
                                                                                       |     mf.manufacturer_name_ja,                                                                                                      +
                                                                                       |     sr.series_code,                                                                                                               +
                                                                                       |     sr.series_name,                                                                                                               +
                                                                                       |     sr.series_name_ja,                                                                                                            +
                                                                                       |     m.model_code,                                                                                                                 +
                                                                                       |     m.model_no,                                                                                                                   +
                                                                                       |     m.machine_name,                                                                                                               +
                                                                                       |     m.machine_name_ja,                                                                                                            +
                                                                                       |     m.product_name,                                                                                                               +
                                                                                       |     m.product_name_ja,                                                                                                            +
                                                                                       |     m.model_summary,                                                                                                              +
                                                                                       |     m.role_class_code,                                                                                                            +
                                                                                       |     rc.role_class_name,                                                                                                           +
                                                                                       |     rc.role_class_name_ja,                                                                                                        +
                                                                                       |     rc.governance_rank_no,                                                                                                        +
                                                                                       |     rc.combat_related,                                                                                                            +
                                                                                       |     id.series_prefix_code,                                                                                                        +
                                                                                       |     id.style_no,                                                                                                                  +
                                                                                       |     id.presentation_gender_code,                                                                                                  +
                                                                                       |     id.version_no,                                                                                                                +
                                                                                       |     sa.style_code,                                                                                                                +
                                                                                       |     st.style_name,                                                                                                                +
                                                                                       |     st.style_name_ja,                                                                                                             +
                                                                                       |     st.style_summary,                                                                                                             +
                                                                                       |     st.initiative_code,                                                                                                           +
                                                                                       |     st.warmth_code,                                                                                                               +
                                                                                       |     st.tempo_code,                                                                                                                +
                                                                                       |     st.closeness_code,                                                                                                            +
                                                                                       |     p.public_series_name,                                                                                                         +
                                                                                       |     p.public_stage_name,                                                                                                          +
                                                                                       |     p.live_activity_enabled,                                                                                                      +
                                                                                       |     p.public_profile_summary,                                                                                                     +
                                                                                       |     p.public_disclosure_note,                                                                                                     +
                                                                                       |     COALESCE(jsonb_object_agg(pm.metric_code, jsonb_build_object('name', pm.metric_name, 'value_numeric', pm.metric_value_numeric,.
                                                                                       |. 'value_text', pm.metric_value_text, 'unit', pm.unit_code) ORDER BY pm.sort_order) FILTER (WHERE (pm.metric_code IS NOT NULL)), '{.
                                                                                       |.}'::jsonb) AS public_metrics,                                                                                                     +
                                                                                       |     lower(concat_ws(' '::text, mf.manufacturer_code, mf.manufacturer_name, mf.manufacturer_name_ja, sr.series_code, sr.series_name.
                                                                                       |., sr.series_name_ja, m.model_code, m.model_no, m.machine_name, m.machine_name_ja, m.product_name, m.product_name_ja, COALESCE(rc.r.
                                                                                       |.ole_class_name_ja, ''::text), COALESCE(st.style_name, ''::text), COALESCE(st.style_name_ja, ''::text), COALESCE(id.presentation_ge.
                                                                                       |.nder_code, ''::text), COALESCE(p.public_stage_name, ''::text))) AS model_search_text,                                             +
                                                                                       |     m.sort_order                                                                                                                  +
                                                                                       |    FROM ((((((((aiworker.worker_model_catalog m                                                                                   +
                                                                                       |      JOIN aiworker.manufacturer_catalog mf ON ((mf.manufacturer_code = m.manufacturer_code)))                                     +
                                                                                       |      JOIN aiworker.worker_series_catalog sr ON ((sr.series_code = m.series_code)))                                                +
                                                                                       |      LEFT JOIN aiworker.worker_role_class_catalog rc ON ((rc.role_class_code = m.role_class_code)))                               +
                                                                                       |      LEFT JOIN aiworker.model_identity_spec id ON ((id.model_code = m.model_code)))                                               +
                                                                                       |      LEFT JOIN aiworker.model_style_assignment sa ON (((sa.model_code = m.model_code) AND (sa.enabled = true))))                  +
                                                                                       |      LEFT JOIN aiworker.interaction_style_catalog st ON ((st.style_code = sa.style_code)))                                        +
                                                                                       |      LEFT JOIN aiworker.public_activity_profile p ON (((p.model_code = m.model_code) AND (p.enabled = true))))                    +
                                                                                       |      LEFT JOIN aiworker.public_metric pm ON (((pm.model_code = m.model_code) AND (pm.enabled = true))))                           +
                                                                                       |   WHERE ((m.enabled = true) AND (mf.enabled = true) AND (sr.enabled = true))                                                      +
                                                                                       |   GROUP BY mf.manufacturer_code, mf.manufacturer_name, mf.manufacturer_name_ja, sr.series_code, sr.series_name, sr.series_name_ja,.
                                                                                       |. m.model_code, m.model_no, m.machine_name, m.machine_name_ja, m.product_name, m.product_name_ja, m.model_summary, m.role_class_cod.
                                                                                       |.e, rc.role_class_name, rc.role_class_name_ja, rc.governance_rank_no, rc.combat_related, id.series_prefix_code, id.style_no, id.pre.
                                                                                       |.sentation_gender_code, id.version_no, sa.style_code, st.style_name, st.style_name_ja, st.style_summary, st.initiative_code, st.war.
                                                                                       |.mth_code, st.tempo_code, st.closeness_code, p.public_series_name, p.public_stage_name, p.live_activity_enabled, p.public_profile_s.
                                                                                       |.ummary, p.public_disclosure_note, m.sort_order;
