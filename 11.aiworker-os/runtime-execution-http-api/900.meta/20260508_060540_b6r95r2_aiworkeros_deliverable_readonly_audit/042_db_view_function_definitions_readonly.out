                                                                                       |             WHEN 'implementation_delivery_summary'::text THEN '実装 納品サマリー'::text                                           +
                                                                                       |             WHEN 'exception_review'::text THEN '例外・人間判断'::text                                                             +
                                                                                       |             WHEN 'final_delivery_summary'::text THEN '最終納品サマリー'::text                                                     +
