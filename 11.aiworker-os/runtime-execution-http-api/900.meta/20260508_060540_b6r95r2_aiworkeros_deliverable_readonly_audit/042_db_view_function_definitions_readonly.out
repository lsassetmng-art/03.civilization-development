                                                                                       |     p.series_code,                                                                                                                +
                                                                                       |     p.series_name_ja,                                                                                                             +
                                                                                       |     p.role_layer_code,                                                                                                            +
                                                                                       |     p.role_layer_name_ja,                                                                                                         +
                                                                                       |     p.task_domain_code,                                                                                                           +
                                                                                       |     p.task_title,                                                                                                                 +
