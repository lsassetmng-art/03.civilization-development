 ===== VIEW aiworker.vw_app_aiworker_runtime_execution_endpoint_ready_v1 =====         |  SELECT count(*) AS contract_count,                                                                                               +
                                                                                       |     count(*) FILTER (WHERE read_only_flag) AS read_endpoint_count,                                                                +
                                                                                       |     count(*) FILTER (WHERE write_allowed_flag) AS write_endpoint_count,                                                           +
                                                                                       |     count(*) FILTER (WHERE internal_write_allowed_flag) AS internal_write_endpoint_count,                                         +
                                                                                       |     bool_and((NOT external_execution_allowed_flag)) AS all_external_execution_blocked,                                            +
                                                                                       |     bool_and((NOT pg_apply_allowed_flag)) AS all_pg_apply_blocked,                                                                +
                                                                                       |     bool_and((NOT destructive_action_allowed_flag)) AS all_destructive_action_blocked,                                            +
                                                                                       |     bool_and(auth_required_flag) AS all_auth_required,                                                                            +
                                                                                       |     max(updated_at) AS latest_contract_updated_at                                                                                 +
                                                                                       |    FROM aiworker.runtime_execution_app_api_contract                                                                               +
                                                                                       |   WHERE (status_code = 'active'::text);
