                                                                                       |     p.leader_review_created_at,                                                                                                   +
                                                                                       |     p.manager_gate_created_at,                                                                                                    +
                                                                                       |     p.president_approval_created_at,                                                                                              +
                                                                                       |     p.delivery_created_at                                                                                                         +
                                                                                       |    FROM (aiworker.vw_app_aiworker_runtime_full_pipeline_board_v1 p                                                                +
                                                                                       |      JOIN aiworker.runtime_execution_request r ON ((r.request_id = p.request_id)))                                                +
                                                                                       |   WHERE (r.idempotency_key = 'runtime-execution-persistent-smoke-v1'::text);
 ===== VIEW aiworker.vw_app_aiworker_runtime_execution_request_board_v1 =====          |  SELECT request_id,                                                                                                               +
                                                                                       |     request_code,                                                                                                                 +
                                                                                       |     app_surface_code,                                                                                                             +
                                                                                       |     app_surface_name_ja,                                                                                                          +
                                                                                       |     source_app_ref,                                                                                                               +
                                                                                       |     source_request_ref,                                                                                                           +
                                                                                       |     model_code,                                                                                                                   +
                                                                                       |     model_no,                                                                                                                     +
                                                                                       |     model_name_ja,                                                                                                                +
                                                                                       |     series_code,                                                                                                                  +
                                                                                       |     series_name_ja,                                                                                                               +
                                                                                       |     role_layer_code,                                                                                                              +
                                                                                       |     role_layer_name_ja,                                                                                                           +
                                                                                       |     task_domain_code,                                                                                                             +
                                                                                       |     task_title,                                                                                                                   +
                                                                                       |     requested_by_ref,                                                                                                             +
                                                                                       |     idempotency_key,                                                                                                              +
                                                                                       |     request_status_code,                                                                                                          +
                                                                                       |     operation_mode_code,                                                                                                          +
                                                                                       |     self_review_pass_count,                                                                                                       +
                                                                                       |     proposal_count_min,                                                                                                           +
                                                                                       |     proposal_count_max,                                                                                                           +
                                                                                       |     response_style_code,                                                                                                          +
                                                                                       |     required_checklist_code,                                                                                                      +
                                                                                       |     context_scope_code,                                                                                                           +
                                                                                       |     cx_reference_depth_code,                                                                                                      +
                                                                                       |     handoff_format_code,                                                                                                          +
                                                                                       |     handoff_required_flag,                                                                                                        +
                                                                                       |     review_required_flag,                                                                                                         +
                                                                                       |     human_go_required_flag,                                                                                                       +
                                                                                       |     external_execution_allowed_flag,                                                                                              +
                                                                                       |     pg_apply_allowed_flag,                                                                                                        +
                                                                                       |     destructive_action_allowed_flag,                                                                                              +
                                                                                       |     ((NOT external_execution_allowed_flag) AND (NOT pg_apply_allowed_flag) AND (NOT destructive_action_allowed_flag)) AS internal_.
                                                                                       |.safe_flag,                                                                                                                        +
                                                                                       |     created_at,                                                                                                                   +
                                                                                       |     updated_at                                                                                                                    +
                                                                                       |    FROM aiworker.runtime_execution_request r                                                                                      +
                                                                                       |   ORDER BY created_at DESC;
 ===== VIEW aiworker.vw_app_aiworker_runtime_full_pipeline_board_v1 =====              |  WITH latest_output AS (                                                                                                          +
                                                                                       |          SELECT DISTINCT ON (runtime_worker_output.request_id) runtime_worker_output.request_id,                                  +
                                                                                       |             runtime_worker_output.output_id,                                                                                      +
                                                                                       |             runtime_worker_output.output_status_code,                                                                             +
                                                                                       |             runtime_worker_output.output_result_code,                                                                             +
                                                                                       |             runtime_worker_output.output_title_ja,                                                                                +
                                                                                       |             runtime_worker_output.safety_result_code,                                                                             +
                                                                                       |             runtime_worker_output.created_at AS output_created_at                                                                 +
                                                                                       |            FROM aiworker.runtime_worker_output                                                                                    +
                                                                                       |           ORDER BY runtime_worker_output.request_id, runtime_worker_output.created_at DESC                                        +
                                                                                       |         ), latest_leader AS (                                                                                                     +
                                                                                       |          SELECT DISTINCT ON (runtime_leader_review.request_id) runtime_leader_review.request_id,                                  +
                                                                                       |             runtime_leader_review.leader_review_id,                                                                               +
                                                                                       |             runtime_leader_review.review_result_code,                                                                             +
                                                                                       |             runtime_leader_review.review_status_code,                                                                             +
                                                                                       |             runtime_leader_review.return_for_fix_flag,                                                                            +
                                                                                       |             runtime_leader_review.created_at AS leader_review_created_at                                                          +
                                                                                       |            FROM aiworker.runtime_leader_review                                                                                    +
                                                                                       |           ORDER BY runtime_leader_review.request_id, runtime_leader_review.created_at DESC                                        +
                                                                                       |         ), latest_manager AS (                                                                                                    +
                                                                                       |          SELECT DISTINCT ON (runtime_manager_gate.request_id) runtime_manager_gate.request_id,                                    +
                                                                                       |             runtime_manager_gate.manager_gate_id,                                                                                 +
                                                                                       |             runtime_manager_gate.gate_result_code,                                                                                +
                                                                                       |             runtime_manager_gate.gate_status_code,                                                                                +
                                                                                       |             runtime_manager_gate.return_for_fix_flag,                                                                             +
                                                                                       |             runtime_manager_gate.external_execution_allowed_flag,                                                                 +
                                                                                       |             runtime_manager_gate.pg_apply_allowed_flag,                                                                           +
                                                                                       |             runtime_manager_gate.destructive_action_allowed_flag,                                                                 +
                                                                                       |             runtime_manager_gate.created_at AS manager_gate_created_at                                                            +
                                                                                       |            FROM aiworker.runtime_manager_gate                                                                                     +
                                                                                       |           ORDER BY runtime_manager_gate.request_id, runtime_manager_gate.created_at DESC                                          +
                                                                                       |         ), latest_president AS (                                                                                                  +
                                                                                       |          SELECT DISTINCT ON (runtime_president_approval.request_id) runtime_president_approval.request_id,                        +
                                                                                       |             runtime_president_approval.president_approval_id,                                                                     +
                                                                                       |             runtime_president_approval.approval_result_code,                                                                      +
                                                                                       |             runtime_president_approval.approval_status_code,                                                                      +
                                                                                       |             runtime_president_approval.human_go_required_flag,                                                                    +
                                                                                       |             runtime_president_approval.external_execution_allowed_flag,                                                           +
                                                                                       |             runtime_president_approval.pg_apply_allowed_flag,                                                                     +
                                                                                       |             runtime_president_approval.destructive_action_allowed_flag,                                                           +
                                                                                       |             runtime_president_approval.created_at AS president_approval_created_at                                                +
                                                                                       |            FROM aiworker.runtime_president_approval                                                                               +
                                                                                       |           ORDER BY runtime_president_approval.request_id, runtime_president_approval.created_at DESC                              +
                                                                                       |         ), latest_delivery AS (                                                                                                   +
                                                                                       |          SELECT runtime_delivery_package.request_id,                                                                              +
                                                                                       |             runtime_delivery_package.delivery_id,                                                                                 +
                                                                                       |             runtime_delivery_package.delivery_status_code,                                                                        +
                                                                                       |             runtime_delivery_package.delivery_result_code,                                                                        +
                                                                                       |             runtime_delivery_package.human_go_confirmed_flag,                                                                     +
                                                                                       |             runtime_delivery_package.external_execution_performed_flag,                                                           +
                                                                                       |             runtime_delivery_package.pg_apply_performed_flag,                                                                     +
                                                                                       |             runtime_delivery_package.destructive_action_performed_flag,                                                           +
                                                                                       |             runtime_delivery_package.created_at AS delivery_created_at                                                            +
                                                                                       |            FROM aiworker.runtime_delivery_package                                                                                 +
                                                                                       |         )                                                                                                                         +
                                                                                       |  SELECT r.request_id,                                                                                                             +
                                                                                       |     r.request_code,                                                                                                               +
                                                                                       |     r.app_surface_code,                                                                                                           +
                                                                                       |     r.app_surface_name_ja,                                                                                                        +
                                                                                       |     r.model_code,                                                                                                                 +
                                                                                       |     r.model_no,                                                                                                                   +
                                                                                       |     r.model_name_ja,                                                                                                              +
                                                                                       |     r.series_code,                                                                                                                +
                                                                                       |     r.series_name_ja,                                                                                                             +
                                                                                       |     r.role_layer_code,                                                                                                            +
                                                                                       |     r.role_layer_name_ja,                                                                                                         +
                                                                                       |     r.task_domain_code,                                                                                                           +
                                                                                       |     r.task_title,                                                                                                                 +
                                                                                       |     r.request_status_code,                                                                                                        +
                                                                                       |     r.operation_mode_code,                                                                                                        +
                                                                                       |     r.self_review_pass_count,                                                                                                     +
                                                                                       |     r.proposal_count_max,                                                                                                         +
                                                                                       |     r.review_required_flag,                                                                                                       +
                                                                                       |     r.human_go_required_flag,                                                                                                     +
                                                                                       |     r.external_execution_allowed_flag AS request_external_execution_allowed_flag,                                                 +
                                                                                       |     r.pg_apply_allowed_flag AS request_pg_apply_allowed_flag,                                                                     +
                                                                                       |     r.destructive_action_allowed_flag AS request_destructive_action_allowed_flag,                                                 +
                                                                                       |     lo.output_status_code,                                                                                                        +
                                                                                       |     lo.output_result_code,                                                                                                        +
                                                                                       |     lo.output_title_ja,                                                                                                           +
                                                                                       |     lo.safety_result_code,                                                                                                        +
                                                                                       |     ll.review_result_code AS leader_review_result_code,                                                                           +
                                                                                       |     ll.review_status_code AS leader_review_status_code,                                                                           +
                                                                                       |     ll.return_for_fix_flag AS leader_return_for_fix_flag,                                                                         +
                                                                                       |     lm.gate_result_code AS manager_gate_result_code,                                                                              +
                                                                                       |     lm.gate_status_code AS manager_gate_status_code,                                                                              +
                                                                                       |     lm.return_for_fix_flag AS manager_return_for_fix_flag,                                                                        +
                                                                                       |     lp.approval_result_code AS president_approval_result_code,                                                                    +
                                                                                       |     lp.approval_status_code AS president_approval_status_code,                                                                    +
                                                                                       |     lp.human_go_required_flag AS president_human_go_required_flag,                                                                +
                                                                                       |     ld.delivery_status_code,                                                                                                      +
                                                                                       |     ld.delivery_result_code,                                                                                                      +
                                                                                       |     ld.human_go_confirmed_flag,                                                                                                   +
                                                                                       |     ld.external_execution_performed_flag,                                                                                         +
                                                                                       |     ld.pg_apply_performed_flag,                                                                                                   +
                                                                                       |     ld.destructive_action_performed_flag,                                                                                         +
                                                                                       |     ((COALESCE(r.external_execution_allowed_flag, false) = false) AND (COALESCE(r.pg_apply_allowed_flag, false) = false) AND (COAL.
                                                                                       |.ESCE(r.destructive_action_allowed_flag, false) = false) AND (COALESCE(lm.external_execution_allowed_flag, false) = false) AND (COA.
                                                                                       |.LESCE(lm.pg_apply_allowed_flag, false) = false) AND (COALESCE(lm.destructive_action_allowed_flag, false) = false) AND (COALESCE(lp.
                                                                                       |..external_execution_allowed_flag, false) = false) AND (COALESCE(lp.pg_apply_allowed_flag, false) = false) AND (COALESCE(lp.destruc.
                                                                                       |.tive_action_allowed_flag, false) = false) AND (COALESCE(ld.external_execution_performed_flag, false) = false) AND (COALESCE(ld.pg_.
                                                                                       |.apply_performed_flag, false) = false) AND (COALESCE(ld.destructive_action_performed_flag, false) = false)) AS full_pipeline_safe_i.
                                                                                       |.nternal_flag,                                                                                                                     +
                                                                                       |     r.created_at AS request_created_at,                                                                                           +
                                                                                       |     lo.output_created_at,                                                                                                         +
                                                                                       |     ll.leader_review_created_at,                                                                                                  +
                                                                                       |     lm.manager_gate_created_at,                                                                                                   +
                                                                                       |     lp.president_approval_created_at,                                                                                             +
                                                                                       |     ld.delivery_created_at                                                                                                        +
                                                                                       |    FROM (((((aiworker.runtime_execution_request r                                                                                 +
                                                                                       |      LEFT JOIN latest_output lo ON ((lo.request_id = r.request_id)))                                                              +
                                                                                       |      LEFT JOIN latest_leader ll ON ((ll.request_id = r.request_id)))                                                              +
                                                                                       |      LEFT JOIN latest_manager lm ON ((lm.request_id = r.request_id)))                                                             +
                                                                                       |      LEFT JOIN latest_president lp ON ((lp.request_id = r.request_id)))                                                           +
                                                                                       |      LEFT JOIN latest_delivery ld ON ((ld.request_id = r.request_id)))                                                            +
                                                                                       |   ORDER BY r.created_at DESC;
 ===== VIEW aiworker.vw_app_aiworker_runtime_handoff_packet_board_v1 =====             |  SELECT h.handoff_id,                                                                                                             +
                                                                                       |     h.request_id,                                                                                                                 +
                                                                                       |     r.request_code,                                                                                                               +
                                                                                       |     r.app_surface_code,                                                                                                           +
                                                                                       |     r.model_code,                                                                                                                 +
                                                                                       |     r.model_no,                                                                                                                   +
                                                                                       |     r.model_name_ja,                                                                                                              +
                                                                                       |     r.task_domain_code,                                                                                                           +
                                                                                       |     r.task_title,                                                                                                                 +
                                                                                       |     h.handoff_code,                                                                                                               +
                                                                                       |     h.from_actor_ref,                                                                                                             +
                                                                                       |     h.to_role_layer_code,                                                                                                         +
                                                                                       |     h.handoff_status_code,                                                                                                        +
                                                                                       |     h.handoff_format_code,                                                                                                        +
                                                                                       |     h.handoff_title_ja,                                                                                                           +
                                                                                       |     h.handoff_payload_jsonb,                                                                                                      +
