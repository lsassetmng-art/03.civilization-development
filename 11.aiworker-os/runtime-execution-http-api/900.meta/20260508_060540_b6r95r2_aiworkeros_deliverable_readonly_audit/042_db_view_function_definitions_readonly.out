                                                                                       |     r.created_at,                                                                                                                 +
                                                                                       |     r.updated_at,                                                                                                                 +
                                                                                       |     r.metadata_jsonb                                                                                                              +
                                                                                       |    FROM (((business.aicm_human_review_item r                                                                                      +
