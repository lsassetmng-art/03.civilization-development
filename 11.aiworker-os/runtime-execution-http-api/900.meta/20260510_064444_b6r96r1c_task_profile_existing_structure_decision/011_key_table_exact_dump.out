 schemaname |                         viewname                         |                                                                                                                                                                           view_definition                                                                                                                                                                            
------------+----------------------------------------------------------+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 aiworker   | vw_app_aiworker_model_capability_overlay_v1              |  SELECT model_code,                                                                                                                                                                                                                                                                                                                                                 +
            |                                                          |     model_no,                                                                                                                                                                                                                                                                                                                                                       +
            |                                                          |     manufacturer_code,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     series_code,                                                                                                                                                                                                                                                                                                                                                    +
            |                                                          |     jsonb_object_agg(axis_code, jsonb_build_object('axis_name_ja', axis_name_ja, 'value_code', value_code, 'value_name_ja', value_name_ja, 'public_label_ja', public_label_ja, 'summary', public_summary_ja) ORDER BY sort_order) AS model_capability_override_jsonb,                                                                                               +
            |                                                          |     string_agg((axis_name_ja || ':'::text) || public_label_ja, ' / '::text ORDER BY sort_order) AS model_capability_override_summary_ja,                                                                                                                                                                                                                            +
            |                                                          |     count(*) AS override_count                                                                                                                                                                                                                                                                                                                                      +
            |                                                          |    FROM aiworker.vw_robot_model_capability_public_v1                                                                                                                                                                                                                                                                                                                +
            |                                                          |   GROUP BY model_code, model_no, manufacturer_code, series_code;
 aiworker   | vw_app_aiworker_model_selection_capability_card_v1       |  SELECT m.registry_code,                                                                                                                                                                                                                                                                                                                                            +
            |                                                          |     m.manufacturer_code,                                                                                                                                                                                                                                                                                                                                            +
            |                                                          |     m.manufacturer_name,                                                                                                                                                                                                                                                                                                                                            +
            |                                                          |     m.manufacturer_name_ja,                                                                                                                                                                                                                                                                                                                                         +
            |                                                          |     m.series_code,                                                                                                                                                                                                                                                                                                                                                  +
            |                                                          |     m.series_name,                                                                                                                                                                                                                                                                                                                                                  +
            |                                                          |     m.series_name_ja,                                                                                                                                                                                                                                                                                                                                               +
            |                                                          |     m.model_code,                                                                                                                                                                                                                                                                                                                                                   +
            |                                                          |     m.model_no,                                                                                                                                                                                                                                                                                                                                                     +
            |                                                          |     m.model_name,                                                                                                                                                                                                                                                                                                                                                   +
            |                                                          |     m.model_name_ja,                                                                                                                                                                                                                                                                                                                                                +
            |                                                          |     m.role_layer_code,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     m.role_layer_name_ja,                                                                                                                                                                                                                                                                                                                                           +
            |                                                          |     m.model_category_code,                                                                                                                                                                                                                                                                                                                                          +
            |                                                          |     m.public_summary_ja,                                                                                                                                                                                                                                                                                                                                            +
            |                                                          |     m.capability_summary_ja,                                                                                                                                                                                                                                                                                                                                        +
            |                                                          |     m.personality_summary_ja,                                                                                                                                                                                                                                                                                                                                       +
            |                                                          |     m.safety_note_ja,                                                                                                                                                                                                                                                                                                                                               +
            |                                                          |     m.public_traits_jsonb,                                                                                                                                                                                                                                                                                                                                          +
            |                                                          |     m.recommended_usage_jsonb,                                                                                                                                                                                                                                                                                                                                      +
            |                                                          |     m.source_layer_code,                                                                                                                                                                                                                                                                                                                                            +
            |                                                          |     s.precision_ja AS series_precision_ja,                                                                                                                                                                                                                                                                                                                          +
            |                                                          |     s.agility_ja AS series_agility_ja,                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     s.coordination_ja AS series_coordination_ja,                                                                                                                                                                                                                                                                                                                    +
            |                                                          |     s.continuity_ja AS series_continuity_ja,                                                                                                                                                                                                                                                                                                                        +
            |                                                          |     s.specialization_depth_ja AS series_specialization_depth_ja,                                                                                                                                                                                                                                                                                                    +
            |                                                          |     s.creativity_ja AS series_creativity_ja,                                                                                                                                                                                                                                                                                                                        +
            |                                                          |     s.review_depth_ja AS series_review_depth_ja,                                                                                                                                                                                                                                                                                                                    +
            |                                                          |     s.stability_ja AS series_stability_ja,                                                                                                                                                                                                                                                                                                                          +
            |                                                          |     s.capability_jsonb AS series_capability_jsonb,                                                                                                                                                                                                                                                                                                                  +
            |                                                          |     COALESCE(o.model_capability_override_jsonb, '{}'::jsonb) AS model_capability_override_jsonb,                                                                                                                                                                                                                                                                    +
            |                                                          |     COALESCE(o.model_capability_override_summary_ja, ''::text) AS model_capability_override_summary_ja,                                                                                                                                                                                                                                                             +
            |                                                          |     COALESCE(o.override_count, 0::bigint) AS model_capability_override_count,                                                                                                                                                                                                                                                                                       +
            |                                                          |     jsonb_build_object('series', COALESCE(s.capability_jsonb, '{}'::jsonb), 'model_override', COALESCE(o.model_capability_override_jsonb, '{}'::jsonb)) AS capability_card_jsonb,                                                                                                                                                                                   +
            |                                                          |         CASE                                                                                                                                                                                                                                                                                                                                                        +
            |                                                          |             WHEN m.model_code = 'hd_r2_battler'::text THEN '戦闘員・フィクション/警備設計/危機管理'::text                                                                                                                                                                                                                                                           +
            |                                                          |             WHEN m.series_code = 'beyond_series'::text THEN '高機能・実務特化・高精度レビュー・複雑作業対応'::text                                                                                                                                                                                                                                                  +
            |                                                          |             WHEN m.series_code = 'lovers_series'::text THEN '会話・接客・感情体験・関係性文脈'::text                                                                                                                                                                                                                                                                +
            |                                                          |             WHEN m.series_code = 'megami_series'::text THEN '時間軸特化・過去/現在/未来の判断軸'::text                                                                                                                                                                                                                                                              +
            |                                                          |             WHEN m.series_code = 'hd_series'::text THEN '汎用・安定・標準運用'::text                                                                                                                                                                                                                                                                                +
            |                                                          |             ELSE '標準'::text                                                                                                                                                                                                                                                                                                                                       +
            |                                                          |         END AS app_selection_badge_ja,                                                                                                                                                                                                                                                                                                                              +
            |                                                          |         CASE                                                                                                                                                                                                                                                                                                                                                        +
            |                                                          |             WHEN m.series_code = 'beyond_series'::text THEN true                                                                                                                                                                                                                                                                                                    +
            |                                                          |             ELSE false                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |         END AS high_function_business_specialized_flag,                                                                                                                                                                                                                                                                                                             +
            |                                                          |     m.sort_order                                                                                                                                                                                                                                                                                                                                                    +
            |                                                          |    FROM aiworker.vw_app_aiworker_model_selection_directory_v1 m                                                                                                                                                                                                                                                                                                     +
            |                                                          |      LEFT JOIN aiworker.vw_robot_series_capability_matrix_public_v1 s ON s.manufacturer_code = m.manufacturer_code AND s.series_code = m.series_code                                                                                                                                                                                                                +
            |                                                          |      LEFT JOIN aiworker.vw_app_aiworker_model_capability_overlay_v1 o ON o.model_code = m.model_code                                                                                                                                                                                                                                                                +
            |                                                          |   ORDER BY m.sort_order, m.series_code, m.model_no;
 aiworker   | vw_app_aiworker_model_selection_directory_v1             |  SELECT registry_code,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     manufacturer_code,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     manufacturer_name,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     manufacturer_name_ja,                                                                                                                                                                                                                                                                                                                                           +
            |                                                          |     series_code,                                                                                                                                                                                                                                                                                                                                                    +
            |                                                          |     series_name,                                                                                                                                                                                                                                                                                                                                                    +
            |                                                          |     series_name_ja,                                                                                                                                                                                                                                                                                                                                                 +
            |                                                          |     model_code,                                                                                                                                                                                                                                                                                                                                                     +
            |                                                          |     model_no,                                                                                                                                                                                                                                                                                                                                                       +
            |                                                          |     model_name,                                                                                                                                                                                                                                                                                                                                                     +
            |                                                          |     model_name_ja,                                                                                                                                                                                                                                                                                                                                                  +
            |                                                          |     role_layer_code,                                                                                                                                                                                                                                                                                                                                                +
            |                                                          |     role_layer_name_ja,                                                                                                                                                                                                                                                                                                                                             +
            |                                                          |     model_category_code,                                                                                                                                                                                                                                                                                                                                            +
            |                                                          |     public_summary_ja,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     capability_summary_ja,                                                                                                                                                                                                                                                                                                                                          +
            |                                                          |     personality_summary_ja,                                                                                                                                                                                                                                                                                                                                         +
            |                                                          |     safety_note_ja,                                                                                                                                                                                                                                                                                                                                                 +
            |                                                          |     public_traits_jsonb,                                                                                                                                                                                                                                                                                                                                            +
            |                                                          |     recommended_usage_jsonb,                                                                                                                                                                                                                                                                                                                                        +
            |                                                          |     source_layer_code,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     sort_order                                                                                                                                                                                                                                                                                                                                                      +
            |                                                          |    FROM aiworker.model_public_registry                                                                                                                                                                                                                                                                                                                              +
            |                                                          |   WHERE status_code = 'active'::text AND public_display_allowed_flag = true AND app_reference_allowed_flag = true;
 aiworker   | vw_app_aiworker_model_selection_source_for_capability_v1 |  SELECT registry_code,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     manufacturer_code,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     manufacturer_name,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     manufacturer_name_ja,                                                                                                                                                                                                                                                                                                                                           +
            |                                                          |     series_code,                                                                                                                                                                                                                                                                                                                                                    +
            |                                                          |     series_name,                                                                                                                                                                                                                                                                                                                                                    +
            |                                                          |     series_name_ja,                                                                                                                                                                                                                                                                                                                                                 +
            |                                                          |     model_code,                                                                                                                                                                                                                                                                                                                                                     +
            |                                                          |     model_no,                                                                                                                                                                                                                                                                                                                                                       +
            |                                                          |     model_name,                                                                                                                                                                                                                                                                                                                                                     +
            |                                                          |     model_name_ja,                                                                                                                                                                                                                                                                                                                                                  +
            |                                                          |     role_layer_code,                                                                                                                                                                                                                                                                                                                                                +
            |                                                          |     role_layer_name_ja,                                                                                                                                                                                                                                                                                                                                             +
            |                                                          |     model_category_code,                                                                                                                                                                                                                                                                                                                                            +
            |                                                          |     public_summary_ja,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     capability_summary_ja,                                                                                                                                                                                                                                                                                                                                          +
            |                                                          |     personality_summary_ja,                                                                                                                                                                                                                                                                                                                                         +
            |                                                          |     safety_note_ja,                                                                                                                                                                                                                                                                                                                                                 +
            |                                                          |     public_traits_jsonb,                                                                                                                                                                                                                                                                                                                                            +
            |                                                          |     recommended_usage_jsonb,                                                                                                                                                                                                                                                                                                                                        +
            |                                                          |     source_layer_code,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     sort_order                                                                                                                                                                                                                                                                                                                                                      +
            |                                                          |    FROM aiworker.vw_app_aiworker_model_selection_directory_v1;
 aiworker   | vw_app_aiworker_model_selection_summary_v1               |  SELECT manufacturer_code,                                                                                                                                                                                                                                                                                                                                          +
            |                                                          |     manufacturer_name,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     series_code,                                                                                                                                                                                                                                                                                                                                                    +
            |                                                          |     series_name_ja,                                                                                                                                                                                                                                                                                                                                                 +
            |                                                          |     count(*) AS model_count,                                                                                                                                                                                                                                                                                                                                        +
            |                                                          |     count(*) FILTER (WHERE role_layer_code = 'WORKER'::text) AS worker_count,                                                                                                                                                                                                                                                                                       +
            |                                                          |     count(*) FILTER (WHERE role_layer_code = 'LEADER'::text) AS leader_count,                                                                                                                                                                                                                                                                                       +
            |                                                          |     count(*) FILTER (WHERE role_layer_code = 'MANAGER'::text) AS manager_count,                                                                                                                                                                                                                                                                                     +
            |                                                          |     count(*) FILTER (WHERE role_layer_code = 'PRESIDENT'::text) AS president_count,                                                                                                                                                                                                                                                                                 +
            |                                                          |     count(*) FILTER (WHERE role_layer_code = 'FRIEND'::text) AS friend_count,                                                                                                                                                                                                                                                                                       +
            |                                                          |     count(*) FILTER (WHERE role_layer_code = 'LOVER'::text) AS lover_count,                                                                                                                                                                                                                                                                                         +
            |                                                          |     count(*) FILTER (WHERE role_layer_code = 'MULTI_ROLE'::text) AS multi_role_count,                                                                                                                                                                                                                                                                               +
            |                                                          |     min(sort_order) AS sort_order                                                                                                                                                                                                                                                                                                                                   +
            |                                                          |    FROM aiworker.vw_app_aiworker_model_selection_directory_v1                                                                                                                                                                                                                                                                                                       +
            |                                                          |   GROUP BY manufacturer_code, manufacturer_name, series_code, series_name_ja;
 aiworker   | vw_app_robot_capability_profile_directory_v1             |  SELECT s.manufacturer_code,                                                                                                                                                                                                                                                                                                                                        +
            |                                                          |     s.series_code,                                                                                                                                                                                                                                                                                                                                                  +
            |                                                          |     s.precision_ja,                                                                                                                                                                                                                                                                                                                                                 +
            |                                                          |     s.agility_ja,                                                                                                                                                                                                                                                                                                                                                   +
            |                                                          |     s.coordination_ja,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     s.continuity_ja,                                                                                                                                                                                                                                                                                                                                                +
            |                                                          |     s.specialization_depth_ja,                                                                                                                                                                                                                                                                                                                                      +
            |                                                          |     s.creativity_ja,                                                                                                                                                                                                                                                                                                                                                +
            |                                                          |     s.review_depth_ja,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     s.stability_ja,                                                                                                                                                                                                                                                                                                                                                 +
            |                                                          |     s.capability_jsonb,                                                                                                                                                                                                                                                                                                                                             +
            |                                                          |     p.sharing_scope_code,                                                                                                                                                                                                                                                                                                                                           +
            |                                                          |     p.sharing_scope_label_ja,                                                                                                                                                                                                                                                                                                                                       +
            |                                                          |     p.allowed_context_jsonb,                                                                                                                                                                                                                                                                                                                                        +
            |                                                          |     p.forbidden_context_jsonb,                                                                                                                                                                                                                                                                                                                                      +
            |                                                          |     p.policy_summary_ja                                                                                                                                                                                                                                                                                                                                             +
            |                                                          |    FROM aiworker.vw_robot_series_capability_matrix_public_v1 s                                                                                                                                                                                                                                                                                                      +
            |                                                          |      LEFT JOIN aiworker.vw_robot_capability_sharing_policy_public_v1 p ON p.manufacturer_code = s.manufacturer_code AND p.series_code = s.series_code                                                                                                                                                                                                               +
            |                                                          |   ORDER BY (                                                                                                                                                                                                                                                                                                                                                        +
            |                                                          |         CASE s.series_code                                                                                                                                                                                                                                                                                                                                          +
            |                                                          |             WHEN 'hd_series'::text THEN 10                                                                                                                                                                                                                                                                                                                          +
            |                                                          |             WHEN 'lovers_series'::text THEN 20                                                                                                                                                                                                                                                                                                                      +
            |                                                          |             WHEN 'beyond_series'::text THEN 30                                                                                                                                                                                                                                                                                                                      +
            |                                                          |             WHEN 'megami_series'::text THEN 40                                                                                                                                                                                                                                                                                                                      +
            |                                                          |             ELSE 999                                                                                                                                                                                                                                                                                                                                                +
            |                                                          |         END);
 aiworker   | vw_robot_brain_compact_context_v1                        |  SELECT model_code,                                                                                                                                                                                                                                                                                                                                                 +
            |                                                          |     series_code,                                                                                                                                                                                                                                                                                                                                                    +
            |                                                          |     role_code,                                                                                                                                                                                                                                                                                                                                                      +
            |                                                          |     brain_domain_code,                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     brain_domain_label_ja,                                                                                                                                                                                                                                                                                                                                          +
            |                                                          |     max(data_depth_level) AS max_data_depth_level,                                                                                                                                                                                                                                                                                                                  +
            |                                                          |     max(depth_code) AS representative_depth_code,                                                                                                                                                                                                                                                                                                                   +
            |                                                          |     array_agg(DISTINCT risk_class_code ORDER BY risk_class_code) AS risk_class_codes,                                                                                                                                                                                                                                                                               +
            |                                                          |     count(*) AS readable_source_count,                                                                                                                                                                                                                                                                                                                              +
            |                                                          |     count(*) FILTER (WHERE source_exists_flag = true) AS existing_source_count,                                                                                                                                                                                                                                                                                     +
            |                                                          |     string_agg((((source_schema_name || '.'::text) || source_object_name) || ':'::text) || brain_data_code, '                                                                                                                                                                                                                                                       +
            |                                                          | '::text ORDER BY source_schema_name, source_object_name, brain_data_code) AS compact_brain_sources,                                                                                                                                                                                                                                                                 +
            |                                                          |     string_agg(DISTINCT registry_safety_boundary_ja, '                                                                                                                                                                                                                                                                                                              +
            |                                                          | ---                                                                                                                                                                                                                                                                                                                                                                 +
            |                                                          | '::text) AS safety_boundaries_ja                                                                                                                                                                                                                                                                                                                                    +
            |                                                          |    FROM aiworker.vw_robot_readable_brain_source_registry_v1                                                                                                                                                                                                                                                                                                         +
            |                                                          |   GROUP BY model_code, series_code, role_code, brain_domain_code, brain_domain_label_ja;
 aiworker   | vw_robot_brain_effective_access_v1                       |  WITH profile_source AS (                                                                                                                                                                                                                                                                                                                                           +
            |                                                          |          SELECT 'model'::text AS profile_source_type,                                                                                                                                                                                                                                                                                                               +
            |                                                          |             robot_brain_model_profile.model_code,                                                                                                                                                                                                                                                                                                                   +
            |                                                          |             robot_brain_model_profile.series_code,                                                                                                                                                                                                                                                                                                                  +
            |                                                          |             robot_brain_model_profile.role_code,                                                                                                                                                                                                                                                                                                                    +
            |                                                          |             robot_brain_model_profile.access_tier_code,                                                                                                                                                                                                                                                                                                             +
            |                                                          |             robot_brain_model_profile.max_depth_code,                                                                                                                                                                                                                                                                                                               +
            |                                                          |             robot_brain_model_profile.focus_domain_codes,                                                                                                                                                                                                                                                                                                           +
            |                                                          |             robot_brain_model_profile.default_use_purpose_codes,                                                                                                                                                                                                                                                                                                    +
            |                                                          |             robot_brain_model_profile.safety_note_ja,                                                                                                                                                                                                                                                                                                               +
            |                                                          |             robot_brain_model_profile.active_flag                                                                                                                                                                                                                                                                                                                   +
            |                                                          |            FROM aiworker.robot_brain_model_profile                                                                                                                                                                                                                                                                                                                  +
            |                                                          |           WHERE robot_brain_model_profile.active_flag = true                                                                                                                                                                                                                                                                                                        +
            |                                                          |         UNION ALL                                                                                                                                                                                                                                                                                                                                                   +
            |                                                          |          SELECT 'series'::text AS profile_source_type,                                                                                                                                                                                                                                                                                                              +
            |                                                          |             'SERIES:'::text || robot_brain_series_profile.series_code AS model_code,                                                                                                                                                                                                                                                                                +
            |                                                          |             robot_brain_series_profile.series_code,                                                                                                                                                                                                                                                                                                                 +
            |                                                          |             robot_brain_series_profile.role_code,                                                                                                                                                                                                                                                                                                                   +
            |                                                          |             robot_brain_series_profile.access_tier_code,                                                                                                                                                                                                                                                                                                            +
            |                                                          |             robot_brain_series_profile.max_depth_code,                                                                                                                                                                                                                                                                                                              +
            |                                                          |             robot_brain_series_profile.focus_domain_codes,                                                                                                                                                                                                                                                                                                          +
            |                                                          |             robot_brain_series_profile.default_use_purpose_codes,                                                                                                                                                                                                                                                                                                   +
            |                                                          |             robot_brain_series_profile.safety_note_ja,                                                                                                                                                                                                                                                                                                              +
            |                                                          |             robot_brain_series_profile.active_flag                                                                                                                                                                                                                                                                                                                  +
            |                                                          |            FROM aiworker.robot_brain_series_profile                                                                                                                                                                                                                                                                                                                 +
            |                                                          |           WHERE robot_brain_series_profile.active_flag = true                                                                                                                                                                                                                                                                                                       +
            |                                                          |         ), base AS (                                                                                                                                                                                                                                                                                                                                                +
            |                                                          |          SELECT p.profile_source_type,                                                                                                                                                                                                                                                                                                                              +
            |                                                          |             p.model_code,                                                                                                                                                                                                                                                                                                                                           +
            |                                                          |             p.series_code,                                                                                                                                                                                                                                                                                                                                          +
            |                                                          |             p.role_code,                                                                                                                                                                                                                                                                                                                                            +
            |                                                          |             p.access_tier_code,                                                                                                                                                                                                                                                                                                                                     +
            |                                                          |             p.max_depth_code,                                                                                                                                                                                                                                                                                                                                       +
            |                                                          |             max_depth.depth_level AS max_depth_level,                                                                                                                                                                                                                                                                                                               +
            |                                                          |             p.focus_domain_codes,                                                                                                                                                                                                                                                                                                                                   +
            |                                                          |             p.default_use_purpose_codes,                                                                                                                                                                                                                                                                                                                            +
            |                                                          |             p.safety_note_ja AS profile_safety_note_ja,                                                                                                                                                                                                                                                                                                             +
            |                                                          |             r.brain_data_code,                                                                                                                                                                                                                                                                                                                                      +
            |                                                          |             r.brain_domain_code,                                                                                                                                                                                                                                                                                                                                    +
            |                                                          |             r.brain_domain_label_ja,                                                                                                                                                                                                                                                                                                                                +
            |                                                          |             r.source_schema_name,                                                                                                                                                                                                                                                                                                                                   +
            |                                                          |             r.source_object_name,                                                                                                                                                                                                                                                                                                                                   +
            |                                                          |             r.source_record_code,                                                                                                                                                                                                                                                                                                                                   +
            |                                                          |             r.source_title_ja,                                                                                                                                                                                                                                                                                                                                      +
            |                                                          |             r.depth_code,                                                                                                                                                                                                                                                                                                                                           +
            |                                                          |             r.depth_level AS data_depth_level,                                                                                                                                                                                                                                                                                                                      +
            |                                                          |             r.depth_label_ja,                                                                                                                                                                                                                                                                                                                                       +
            |                                                          |             r.allowed_use_purpose_codes AS registry_allowed_use_purpose_codes,                                                                                                                                                                                                                                                                                      +
            |                                                          |             r.risk_class_code,                                                                                                                                                                                                                                                                                                                                      +
            |                                                          |             r.risk_level,                                                                                                                                                                                                                                                                                                                                           +
            |                                                          |             r.risk_class_label_ja,                                                                                                                                                                                                                                                                                                                                  +
            |                                                          |             r.granularity_code,                                                                                                                                                                                                                                                                                                                                     +
            |                                                          |             r.granularity_label_ja,                                                                                                                                                                                                                                                                                                                                 +
            |                                                          |             r.safety_boundary_ja AS registry_safety_boundary_ja,                                                                                                                                                                                                                                                                                                    +
            |                                                          |             r.active_flag AS registry_active_flag,                                                                                                                                                                                                                                                                                                                  +
            |                                                          |             r.source_exists_flag,                                                                                                                                                                                                                                                                                                                                   +
            |                                                          |             mdp.policy_code AS model_domain_policy_code,                                                                                                                                                                                                                                                                                                            +
            |                                                          |             mdp.allowed_use_purpose_codes AS model_allowed_use_purpose_codes,                                                                                                                                                                                                                                                                                       +
            |                                                          |             mdp.safety_note_ja AS model_policy_safety_note_ja,                                                                                                                                                                                                                                                                                                      +
            |                                                          |             rp.policy_code AS role_policy_code,                                                                                                                                                                                                                                                                                                                     +
            |                                                          |             rp.allowed_use_purpose_codes AS role_allowed_use_purpose_codes,                                                                                                                                                                                                                                                                                         +
            |                                                          |             rp.safety_note_ja AS role_policy_safety_note_ja                                                                                                                                                                                                                                                                                                         +
            |                                                          |            FROM profile_source p                                                                                                                                                                                                                                                                                                                                    +
            |                                                          |              JOIN cx22073jw.brain_data_depth_catalog max_depth ON max_depth.depth_code = p.max_depth_code                                                                                                                                                                                                                                                           +
            |                                                          |              CROSS JOIN cx22073jw.vw_brain_data_registry_v1 r                                                                                                                                                                                                                                                                                                       +
            |                                                          |              LEFT JOIN aiworker.robot_brain_model_domain_policy mdp ON mdp.model_code = p.model_code AND mdp.brain_domain_code = r.brain_domain_code AND mdp.active_flag = true                                                                                                                                                                                     +
            |                                                          |              LEFT JOIN aiworker.robot_brain_role_policy rp ON rp.role_code = p.role_code AND rp.brain_domain_code = r.brain_domain_code AND rp.active_flag = true                                                                                                                                                                                                   +
            |                                                          |         ), decision AS (                                                                                                                                                                                                                                                                                                                                            +
            |                                                          |          SELECT b.profile_source_type,                                                                                                                                                                                                                                                                                                                              +
            |                                                          |             b.model_code,                                                                                                                                                                                                                                                                                                                                           +
            |                                                          |             b.series_code,                                                                                                                                                                                                                                                                                                                                          +
            |                                                          |             b.role_code,                                                                                                                                                                                                                                                                                                                                            +
            |                                                          |             b.access_tier_code,                                                                                                                                                                                                                                                                                                                                     +
            |                                                          |             b.max_depth_code,                                                                                                                                                                                                                                                                                                                                       +
            |                                                          |             b.max_depth_level,                                                                                                                                                                                                                                                                                                                                      +
            |                                                          |             b.focus_domain_codes,                                                                                                                                                                                                                                                                                                                                   +
            |                                                          |             b.default_use_purpose_codes,                                                                                                                                                                                                                                                                                                                            +
            |                                                          |             b.profile_safety_note_ja,                                                                                                                                                                                                                                                                                                                               +
            |                                                          |             b.brain_data_code,                                                                                                                                                                                                                                                                                                                                      +
            |                                                          |             b.brain_domain_code,                                                                                                                                                                                                                                                                                                                                    +
            |                                                          |             b.brain_domain_label_ja,                                                                                                                                                                                                                                                                                                                                +
            |                                                          |             b.source_schema_name,                                                                                                                                                                                                                                                                                                                                   +
            |                                                          |             b.source_object_name,                                                                                                                                                                                                                                                                                                                                   +
            |                                                          |             b.source_record_code,                                                                                                                                                                                                                                                                                                                                   +
            |                                                          |             b.source_title_ja,                                                                                                                                                                                                                                                                                                                                      +
            |                                                          |             b.depth_code,                                                                                                                                                                                                                                                                                                                                           +
            |                                                          |             b.data_depth_level,                                                                                                                                                                                                                                                                                                                                     +
            |                                                          |             b.depth_label_ja,                                                                                                                                                                                                                                                                                                                                       +
            |                                                          |             b.registry_allowed_use_purpose_codes,                                                                                                                                                                                                                                                                                                                   +
            |                                                          |             b.risk_class_code,                                                                                                                                                                                                                                                                                                                                      +
            |                                                          |             b.risk_level,                                                                                                                                                                                                                                                                                                                                           +
            |                                                          |             b.risk_class_label_ja,                                                                                                                                                                                                                                                                                                                                  +
            |                                                          |             b.granularity_code,                                                                                                                                                                                                                                                                                                                                     +
            |                                                          |             b.granularity_label_ja,                                                                                                                                                                                                                                                                                                                                 +
            |                                                          |             b.registry_safety_boundary_ja,                                                                                                                                                                                                                                                                                                                          +
            |                                                          |             b.registry_active_flag,                                                                                                                                                                                                                                                                                                                                 +
            |                                                          |             b.source_exists_flag,                                                                                                                                                                                                                                                                                                                                   +
            |                                                          |             b.model_domain_policy_code,                                                                                                                                                                                                                                                                                                                             +
            |                                                          |             b.model_allowed_use_purpose_codes,                                                                                                                                                                                                                                                                                                                      +
            |                                                          |             b.model_policy_safety_note_ja,                                                                                                                                                                                                                                                                                                                          +
            |                                                          |             b.role_policy_code,                                                                                                                                                                                                                                                                                                                                     +
            |                                                          |             b.role_allowed_use_purpose_codes,                                                                                                                                                                                                                                                                                                                       +
            |                                                          |             b.role_policy_safety_note_ja,                                                                                                                                                                                                                                                                                                                           +
            |                                                          |             COALESCE(b.model_allowed_use_purpose_codes, b.role_allowed_use_purpose_codes, b.default_use_purpose_codes, b.registry_allowed_use_purpose_codes) AS effective_use_purpose_codes,                                                                                                                                                                        +
            |                                                          |                 CASE                                                                                                                                                                                                                                                                                                                                                +
            |                                                          |                     WHEN b.registry_active_flag IS NOT TRUE THEN 'deny_registry_inactive'::text                                                                                                                                                                                                                                                                     +
            |                                                          |                     WHEN b.data_depth_level > b.max_depth_level THEN 'deny_depth'::text                                                                                                                                                                                                                                                                             +
            |                                                          |                     WHEN b.model_domain_policy_code = 'deny'::text THEN 'deny_model_policy'::text                                                                                                                                                                                                                                                                   +
            |                                                          |                     WHEN b.role_policy_code = 'deny'::text THEN 'deny_role_policy'::text                                                                                                                                                                                                                                                                            +
            |                                                          |                     WHEN (b.risk_class_code = ANY (ARRAY['high'::text, 'restricted'::text])) AND NOT COALESCE(b.model_allowed_use_purpose_codes, b.role_allowed_use_purpose_codes, b.default_use_purpose_codes, ARRAY[]::text[]) && ARRAY['risk_check'::text, 'design_reference'::text, 'safety_training'::text, 'review'::text] THEN 'deny_high_risk_purpose'::text+
            |                                                          |                     WHEN b.model_domain_policy_code = ANY (ARRAY['allow'::text, 'conditional'::text]) THEN 'allow_model_policy'::text                                                                                                                                                                                                                               +
            |                                                          |                     WHEN b.role_policy_code = ANY (ARRAY['allow'::text, 'conditional'::text]) THEN 'allow_role_policy'::text                                                                                                                                                                                                                                        +
            |                                                          |                     WHEN b.brain_domain_code = ANY (b.focus_domain_codes) THEN 'allow_focus_domain'::text                                                                                                                                                                                                                                                           +
            |                                                          |                     ELSE 'deny_no_allow_policy'::text                                                                                                                                                                                                                                                                                                               +
            |                                                          |                 END AS access_decision_code                                                                                                                                                                                                                                                                                                                         +
            |                                                          |            FROM base b                                                                                                                                                                                                                                                                                                                                              +
            |                                                          |         )                                                                                                                                                                                                                                                                                                                                                           +
            |                                                          |  SELECT profile_source_type,                                                                                                                                                                                                                                                                                                                                        +
            |                                                          |     model_code,                                                                                                                                                                                                                                                                                                                                                     +
            |                                                          |     series_code,                                                                                                                                                                                                                                                                                                                                                    +
            |                                                          |     role_code,                                                                                                                                                                                                                                                                                                                                                      +
            |                                                          |     access_tier_code,                                                                                                                                                                                                                                                                                                                                               +
            |                                                          |     max_depth_code,                                                                                                                                                                                                                                                                                                                                                 +
            |                                                          |     max_depth_level,                                                                                                                                                                                                                                                                                                                                                +
            |                                                          |     brain_data_code,                                                                                                                                                                                                                                                                                                                                                +
            |                                                          |     brain_domain_code,                                                                                                                                                                                                                                                                                                                                              +
