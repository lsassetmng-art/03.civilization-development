# AIWorkerOS live AIWorkerOS local endpoint example
# Copy to .env.local locally. Do not commit real tokens.

export PERSONA_AIWORKEROS_BASE_URL="http://127.0.0.1:8787"
export PERSONA_AIWORKEROS_AUTH_TOKEN="REPLACE_WITH_LOCAL_TOKEN"
export PERSONA_AIWORKEROS_PORT="8787"
export PERSONA_AIWORKEROS_HOST="127.0.0.1"

