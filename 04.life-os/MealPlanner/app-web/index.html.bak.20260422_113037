<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>MealPlanner</title>
  <link rel="stylesheet" href="../../_shared-web/common.css">
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <header class="topbar">
    <h1>MealPlanner</h1>
    <div class="badge">LifeOS Wave 1 Web</div>
  </header>

  <main class="page">
    <section class="hero" id="hero">
      <div class="hero-overlay">
        <h2>MealPlanner</h2>
        <p>Meal planning and intake logging</p>
      </div>
    </section>

    <section class="grid two">
      <section class="card">
        <h3>Persona / Background</h3>
        <label>Persona Name</label>
        <input id="personaName" type="text" placeholder="Enter persona name">

        <label>Background</label>
        <select id="backgroundSelect">
          <option value="sunrise">Sunrise</option>
          <option value="forest">Forest</option>
          <option value="night">Night</option>
          <option value="ocean">Ocean</option>
        </select>

        <div class="actions">
          <button id="saveShellBtn">Save Shell</button>
          <button id="resetShellBtn" class="secondary">Reset Shell</button>
        </div>

        <div id="shellStatus" class="sub" style="margin-top:12px;"></div>
      </section>

      <section class="card">
        <h3>Summary</h3>
        <div id="summary" class="summary-grid"></div>
      </section>
    </section>

    <section class="card">
      <h3>Register</h3>
      <div id="formArea"></div>
    </section>

    <section class="card">
      <div class="toolbar">
        <button id="clearDataBtn" class="secondary">Clear App Data</button>
        <a class="small-link" href="../../portal-web/index.html">Back to LifeOS Portal</a>
      </div>
    </section>

    <section class="card">
      <h3>Records</h3>
      <div id="records" class="list"></div>
    </section>

    <div class="footer-space"></div>
  </main>

  <script src="../../_shared-web/common.js"></script>
  <script src="app.js"></script>
</body>
</html>
