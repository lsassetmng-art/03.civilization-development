<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>LegalSupport</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <header class="topbar">
    <div class="title">LegalSupport</div>
    <div class="badge">LifeOS Web Shell</div>
  </header>

  <main class="page">
    <section class="hero" id="hero">
      <div class="hero-overlay">
        <h1>LegalSupport</h1>
        <p class="subtitle">Runnable web shell</p>
      </div>
    </section>

    <section class="card">
      <h2>Persona / Background</h2>
      <label>Persona Name</label>
      <input id="personaName" type="text" placeholder="Enter persona name">

      <label>Background</label>
      <select id="backgroundSelect">
        <option value="sunrise">Sunrise</option>
        <option value="forest">Forest</option>
        <option value="night">Night</option>
      </select>

      <div class="actions">
        <button id="saveBtn">Save</button>
        <button id="resetBtn" class="secondary">Reset</button>
      </div>
    </section>

    <section class="card">
      <h2>App Shell Status</h2>
      <ul>
        <li>Web shell created</li>
        <li>Android shell created</li>
        <li>iPhone shell created</li>
        <li>Shared contracts folder created</li>
      </ul>
      <div id="statusLine" class="status-line"></div>
    </section>
  </main>

  <script src="app.js"></script>
</body>
</html>
