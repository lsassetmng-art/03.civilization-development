{
  "appName": "PocketSecretary",
  "syncPolicy": {
    "mode": "offline-first",
    "localQueue": true,
    "onlineSync": true,
    "triggers": [
      "app_launch",
      "foreground_resume",
      "online_recovery",
      "manual_sync",
      "send_possible"
    ]
  },
  "retryPolicy": {
    "visualOwner": "CommonOS",
    "states": [
      "retry_wait",
      "failed",
      "processing"
    ]
  },
  "queueVisualRule": {
    "presentationOwner": "CommonOS",
    "businessMeaningOwner": "PocketSecretary"
  },
  "clientCapabilityRegistry": [
    "file_picker",
    "offline_storage",
    "share_sheet",
    "push_notification"
  ],
  "accessibilityPreset": [
    "large_touch_target",
    "screen_reader_label_rule",
    "contrast_safe_default"
  ]
}
