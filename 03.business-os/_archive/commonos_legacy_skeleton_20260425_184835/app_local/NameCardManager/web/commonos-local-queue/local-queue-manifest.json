{
  "appName": "NameCardManager",
  "syncMode": "offline-first",
  "syncTriggers": [
    "app_launch",
    "foreground_resume",
    "online_recovery",
    "manual_sync",
    "send_possible"
  ],
  "retryStates": [
    "retry_wait",
    "failed",
    "processing"
  ],
  "queueKinds": [
    "capture_image_intake",
    "ocr_review",
    "relationship_merge_review"
  ],
  "storageStrategy": {
    "uiAssets": "cache",
    "structuredState": "indexeddb_equivalent",
    "localOutbox": "local_outbox_queue",
    "temporaryAttachment": "local_storage"
  }
}
