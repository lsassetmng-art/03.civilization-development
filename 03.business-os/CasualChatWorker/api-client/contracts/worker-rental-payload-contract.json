{
  "contract_name": "CasualChatWorker WorkerRentalCore Payload Contract",
  "status": "active",
  "app_code": "CasualChatWorker",
  "service_code": "casual_chat_worker",
  "endpoints": [
    {
      "path": "/api/v1/business/worker-rental/service/catalog",
      "method": "GET",
      "required_query": ["app_code", "service_code"]
    },
    {
      "path": "/api/v1/business/worker-rental/entitlement/balance",
      "method": "GET",
      "required_query": ["app_code", "service_code", "user_id", "grant_period"]
    },
    {
      "path": "/api/v1/business/worker-rental/quote",
      "method": "POST",
      "required_body": [
        "app_code",
        "service_code",
        "user_id",
        "worker_owner_schema",
        "worker_id",
        "worker_type",
        "rental_unit_kind",
        "rental_unit_count",
        "requested_entitlement_kind",
        "requested_entitlement_count",
        "currency_code"
      ]
    },
    {
      "path": "/api/v1/business/worker-rental/confirm",
      "method": "POST",
      "required_body": [
        "app_code",
        "service_code",
        "user_id",
        "quote_id",
        "worker_owner_schema",
        "worker_id",
        "worker_type",
        "rental_unit_kind",
        "rental_unit_count",
        "apply_entitlement_count",
        "confirmed_price_jpy"
      ]
    }
  ],
  "casual_chat_worker_rules": {
    "minimum_contract_minutes": 30,
    "app_max_contract_minutes": 120,
    "allowed_minutes": [30, 60, 90, 120],
    "monthly_free_ticket_source_rule": "shortest_contract_duration",
    "monthly_free_ticket_quantity": 2,
    "one_ticket_free_minutes": 30
  }
}
