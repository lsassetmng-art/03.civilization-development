{
  "app": "StreamStudio",
  "version": "phase1",
  "routes": {
    "dashboard": {
      "method": "GET",
      "path": "/api/v1/streamstudio/dashboard"
    },
    "projects": {
      "method": "GET",
      "path": "/api/v1/streamstudio/projects"
    },
    "upload_queue": {
      "method": "GET",
      "path": "/api/v1/streamstudio/upload-queue"
    },
    "project_create": {
      "method": "POST",
      "path": "/api/v1/streamstudio/project/create"
    },
    "upload_create": {
      "method": "POST",
      "path": "/api/v1/streamstudio/upload/create"
    },
    "approval_request": {
      "method": "POST",
      "path": "/api/v1/streamstudio/approval/request"
    },
    "publish_request": {
      "method": "POST",
      "path": "/api/v1/streamstudio/publish/request"
    }
  }
}
