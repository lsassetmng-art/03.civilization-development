{
  "status": "canonical-consumer-display-model-contract",
  "app": "StreamWatch",
  "header_model": {
    "viewer_name": "string",
    "subtitle": "string"
  },
  "home_card_model": {
    "card_id": "string",
    "title": "string",
    "meta": "string",
    "surface_type": "continue_watching | featured"
  },
  "library_card_model": {
    "card_id": "string",
    "title": "string",
    "meta": "string",
    "surface_type": "history_preview"
  },
  "mapping_rules": [
    "profile_bootstrap.viewer_profile.display_name -> header_model.viewer_name",
    "home.continue_watching[*] -> home_card_model(surface_type=continue_watching)",
    "home.featured[*] -> home_card_model(surface_type=featured)",
    "library.history_preview[*] -> library_card_model"
  ]
}
